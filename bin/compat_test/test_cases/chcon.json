        {
            "command": "chcon",
            "description": "chcon: 使用 --reference 从另一文件继承",
            "args": ["--reference=src_file", "target_file"],
            "setup_commands": [
                "echo 'hello world' > src_file",
                "echo 'hello world' > target_file",
                "chcon -t httpd_sys_content_t src_file"
            ],
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": "",
                    "stderr": ""
                },
                "verifications": [
                    {
                        "command": "stat -c '%C' target_file",
                        "expected_exit": 0,
                        "expected_stdout": "system_u:object_r:httpd_sys_content_t:s0\n",
                        "expected_stderr": null
                    }
                ],
                "ignore_fields": {
                    "ignore_exit_code": false,
                    "ignore_stdout": false,
                    "ignore_stderr": false,
                    "ignore_function": false
                }
            },
            "cleanup_commands": [
                "rm -f src_file target_file"
            ],
            "requires_root": true
        },
