{
    "tests": [
        {
            "command": "chcon",
            "description": "chcon: 基本功能修改type",
            "args": ["-t", "tmp_t", "chcon_test_file"],
            "setup_commands": [
                "echo 'hello world' > chcon_test_file"
            ],
            "expectation": {
                "execution": {
                "exit_code": 0,
                "stdout": "",
                "stderr": ""
                },
                "verifications": [
                {
                    "command": "stat -c '%C' chcon_test_file",
                    "expected_exit": 0,
                    "expected_stdout": "testuser_chown\n",
                    "expected_stderr": null
                }
                ],
                "ignore_fields": {
                "ignore_exit_code": false,
                "ignore_stdout": false,
                "ignore_stderr": false,
                "ignore_function": false
                }
            },
            "cleanup_commands": [
                "rm -f chcon_test_file"
            ],
            "requires_root": true
        },
