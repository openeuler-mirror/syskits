    {
        "command": "chgrp",
        "description": "chgrp: 测试递归修改目录及其内容的所属组 (-R)",
        "args": ["-R", "chgrp_test_group4", "test_dir"],
        "setup_commands": [
            "groupadd chgrp_test_group4",
            "mkdir -p test_dir/subdir",
            "touch test_dir/file1.txt test_dir/subdir/file2.txt",
            "chgrp root test_dir test_dir/file1.txt test_dir/subdir test_dir/subdir/file2.txt"
        ],
        "expectation": {
            "execution": {
            "exit_code": 0,
            "stdout": "",
            "stderr": ""
            },
            "verifications": [
            {
                "command": "stat -c '%G' test_dir",
                "expected_exit": 0,
                "expected_stdout": "chgrp_test_group4\n",
                "expected_stderr": null
            },
            {
                "command": "stat -c '%G' test_dir/file1.txt",
                "expected_exit": 0,
                "expected_stdout": "chgrp_test_group4\n",
                "expected_stderr": null
            },
            {
                "command": "stat -c '%G' test_dir/subdir",
                "expected_exit": 0,
                "expected_stdout": "chgrp_test_group4\n",
                "expected_stderr": null
            },
            {
                "command": "stat -c '%G' test_dir/subdir/file2.txt",
                "expected_exit": 0,
                "expected_stdout": "chgrp_test_group4\n",
                "expected_stderr": null
            }
            ],
            "ignore_fields": {
            "ignore_exit_code": false,
            "ignore_stdout": false,
            "ignore_stderr": false,
            "ignore_function": false
            }
        },
        "cleanup_commands": [
            "rm -rf test_dir",
            "groupdel chgrp_test_group4"
        ],
        "requires_root": true
    },
