                "expected_stdout": "chgrp_test_group_recursive_symlink\n",
                "expected_stderr": null
            },
            {
                "command": "stat -c '%G' test_dir/subdir",
                "expected_exit": 0,
                "expected_stdout": "chgrp_test_group_recursive_symlink\n",
                "expected_stderr": null
