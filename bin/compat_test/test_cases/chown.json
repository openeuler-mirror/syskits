        "setup_commands": [
            "useradd testuser_chown_multi",
            "touch file1_chown.txt file2_chown.txt",
            "chown root file1_chown.txt file2_chown.txt",
            "chmod 644 file1_chown.txt file2_chown.txt"
        ],
        "expectation": {
            "execution": {
            "exit_code": 0,
            "stdout": "",
            "stderr": ""
            },
            "verifications": [
            {
                "command": "stat -c '%U' file1_chown.txt",
                "expected_exit": 0,
                "expected_stdout": "testuser_chown_multi\n",
                "expected_stderr": null
            },
            {
                "command": "stat -c '%U' file2_chown.txt",
                "expected_exit": 0,
                "expected_stdout": "testuser_chown_multi\n",
                "expected_stderr": null
            }
            ],
            "ignore_fields": {
            "ignore_exit_code": false,
            "ignore_stdout": false,
            "ignore_stderr": false,
            "ignore_function": false
            }
        },
        "cleanup_commands": [
            "rm -f file1_chown.txt file2_chown.txt",
            "userdel -r testuser_chown_multi"
        ],
        "requires_root": true,
        "timeout": 30
    },
