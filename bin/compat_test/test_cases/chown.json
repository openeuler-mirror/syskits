    {
        "command": "chown",
        "description": "chown: 测试符号链接行为",
        "args": ["testuser_chown_symlink", "link_file_chown"],
        "setup_commands": [
            "useradd testuser_chown_symlink",
            "touch target_file_chown",
            "ln -s target_file_chown link_file_chown",
            "chown root target_file_chown",
            "chmod 644 target_file_chown"
        ],
        "expectation": {
            "execution": {
            "exit_code": 0,
            "stdout": "",
            "stderr": ""
            },
            "verifications": [
            {
                "command": "stat -c '%U' target_file_chown",
                "expected_exit": 0,
                "expected_stdout": "testuser_chown_symlink\n",
                "expected_stderr": null
            },
            {
                "command": "stat -c '%U' link_file_chown",
                "expected_exit": 0,
                "expected_stdout": "root\n",
                "expected_stderr": null
            }
            ],
            "ignore_fields": {
            "ignore_exit_code": false,
            "ignore_stdout": false,
            "ignore_stderr": false,
            "ignore_function": false
            }
        },
        "cleanup_commands": [
            "rm -f target_file_chown link_file_chown",
            "userdel -r testuser_chown_symlink"
        ],
        "requires_root": true
    },
    {
        "command": "chown",
        "description": "chown: -R 遇到指向父目录的符号链接，不跟随且不发生死循环",
        "args": ["-R", "testuser_chown_loop", "loop_dir"],
        "setup_commands": [
            "useradd testuser_chown_loop",
            "mkdir -p loop_dir/subdir",
            "touch loop_dir/file.txt",
            "ln -s .. loop_dir/subdir/back",
            "chown root loop_dir loop_dir/file.txt loop_dir/subdir",
            "chown -h root loop_dir/subdir/back",
            "chmod -R 755 loop_dir"
        ],
        "expectation": {
            "execution": {
            "exit_code": 0,
            "stdout": "",
            "stderr": ""
            },
            "verifications": [
            {
                "command": "stat -c '%U' loop_dir",
                "expected_exit": 0,
                "expected_stdout": "testuser_chown_loop\n"
            },
            {
                "command": "stat -c '%U' loop_dir/file.txt",
                "expected_exit": 0,
                "expected_stdout": "testuser_chown_loop\n"
            },
            {
                "command": "stat -c '%U' loop_dir/subdir",
                "expected_exit": 0,
                "expected_stdout": "testuser_chown_loop\n"
            },
            {
                "command": "stat -c '%U' loop_dir/subdir/back",
                "expected_exit": 0,
                "expected_stdout": "testuser_chown_loop\n"
            }
            ],
            "ignore_fields": {
            "ignore_exit_code": false,
            "ignore_stdout": false,
            "ignore_stderr": false,
            "ignore_function": false
            }
        },
        "cleanup_commands": [
            "rm -rf loop_dir",
            "userdel -r testuser_chown_loop"
        ],
        "requires_root": true,
        "timeout": 10
    },
    {
        "command": "chown",
        "description": "chown: 同时修改文件的 owner 和 group (user:group)",
        "args": ["testuser_chown_both:testgroup_chown_both", "test_file_chown_both"],
        "setup_commands": [
            "useradd testuser_chown_both",
            "groupadd testgroup_chown_both",
            "touch test_file_chown_both",
            "chown root:root test_file_chown_both",
            "chmod 644 test_file_chown_both"
        ],
        "expectation": {
            "execution": {
                "exit_code": 0,
                "stdout": "",
                "stderr": ""
            },
            "verifications": [
                {
                    "command": "stat -c '%U' test_file_chown_both",
