    {
        "command": "chown",
        "description": "chown: 测试递归修改目录及子文件/子目录的 owner",
        "args": ["-R", "testuser_chown_recursive", "test_dir_chown"],
        "setup_commands": [
            "useradd testuser_chown_recursive",
            "mkdir -p test_dir_chown/subdir",
            "touch test_dir_chown/file1.txt test_dir_chown/subdir/file2.txt",
            "chown root test_dir_chown test_dir_chown/file1.txt test_dir_chown/subdir test_dir_chown/subdir/file2.txt",
            "chmod -R 755 test_dir_chown"
        ],
        "expectation": {
            "execution": {
            "exit_code": 0,
            "stdout": "",
            "stderr": ""
            },
            "verifications": [
            {
                "command": "stat -c '%U' test_dir_chown",
                "expected_exit": 0,
                "expected_stdout": "testuser_chown_recursive\n",
                "expected_stderr": null
            },
            {
                "command": "stat -c '%U' test_dir_chown/file1.txt",
                "expected_exit": 0,
                "expected_stdout": "testuser_chown_recursive\n",
                "expected_stderr": null
            },
            {
                "command": "stat -c '%U' test_dir_chown/subdir",
                "expected_exit": 0,
                "expected_stdout": "testuser_chown_recursive\n",
                "expected_stderr": null
            },
            {
                "command": "stat -c '%U' test_dir_chown/subdir/file2.txt",
                "expected_exit": 0,
                "expected_stdout": "testuser_chown_recursive\n",
                "expected_stderr": null
            }
            ],
            "ignore_fields": {
            "ignore_exit_code": false,
            "ignore_stdout": false,
            "ignore_stderr": false,
            "ignore_function": false
            }
        },
        "cleanup_commands": [
            "rm -rf test_dir_chown",
            "userdel -r testuser_chown_recursive"
        ],
        "requires_root": true
    },
