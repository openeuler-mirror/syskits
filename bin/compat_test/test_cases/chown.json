{
  "tests": [
    {
        "command": "chown",
        "description": "chown: 测试单个普通文件修改 owner",
        "args": ["testuser_chown", "test_file_chown"],
        "setup_commands": [
            "useradd testuser_chown",
            "touch test_file_chown",
            "chown root test_file_chown",
            "chmod 644 test_file_chown"
        ],
        "expectation": {
            "execution": {
            "exit_code": 0,
            "stdout": "",
            "stderr": ""
            },
            "verifications": [
            {
                "command": "stat -c '%U' test_file_chown",
                "expected_exit": 0,
                "expected_stdout": "testuser_chown\n",
                "expected_stderr": null
            }
            ],
            "ignore_fields": {
            "ignore_exit_code": false,
            "ignore_stdout": false,
            "ignore_stderr": false,
            "ignore_function": false
            }
        },
        "cleanup_commands": [
            "rm -f test_file_chown",
            "userdel -r testuser_chown"
        ],
        "requires_root": true,
        "timeout": 30
    },
    {
        "command": "chown",
