                    "expected_stdout": "testuser_chown_both\n",
                    "expected_stderr": null
                },
                {
                    "command": "stat -c '%G' test_file_chown_both",
                    "expected_exit": 0,
                    "expected_stdout": "testgroup_chown_both\n",
                    "expected_stderr": null
                }
            ],
            "ignore_fields": {
                "ignore_exit_code": false,
                "ignore_stdout": false,
                "ignore_stderr": false,
                "ignore_function": false
            }
        },
        "cleanup_commands": [
            "rm -f test_file_chown_both",
            "userdel -r testuser_chown_both",
            "groupdel testgroup_chown_both"
        ],
        "requires_root": true
    },
