        {
            "command": "chroot",
            "description": "chroot: 在新根下执行不带参数的命令",
            "args": ["./chroot_test_dir", "/bin/ls"],
            "setup_commands": [
                "mkdir -p ./chroot_test_dir/{bin,lib64}",
                "cp /usr/bin/ls ./chroot_test_dir/bin/",
                "cp /usr/lib64/libselinux.so.1 ./chroot_test_dir/lib64/",
                "cp /usr/lib64/libcap.so.2 ./chroot_test_dir/lib64/",
                "cp /usr/lib64/libc.so.6 ./chroot_test_dir/lib64/",
                "cp /usr/lib64/libpcre2-8.so.0 ./chroot_test_dir/lib64/",
                "cp /lib64/ld-linux-x86-64.so.2 ./chroot_test_dir/lib64/"
            ],
            "expectation": {
                "execution": {
                "exit_code": 0,
                "stdout": "bin\nlib64\n",
                "stderr": ""
                },
                "verifications": [
                ],
                "ignore_fields": {
                "ignore_exit_code": false,
                "ignore_stdout": false,
                "ignore_stderr": false,
                "ignore_function": false
                }
            },
            "cleanup_commands": [
                "rm -rf ./chroot_test_dir"
            ],
            "requires_root": true
        },
