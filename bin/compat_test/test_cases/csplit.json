                    }
                ],
                "ignore_fields": {
                    "ignore_exit_code": false,
                    "ignore_stdout": false,
                    "ignore_stderr": false,
                    "ignore_function": false
                }
            },
            "cleanup_commands": [
                "rm -f csplit_input.txt xx*"
            ]
        },
