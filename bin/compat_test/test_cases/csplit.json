          { "command": "test -f xx00 && test -f xx01", "expected_exit": 0, "expected_stdout": null, "expected_stderr": null },
          { "command": "wc -c xx00 xx01", "expected_exit": 0, "expected_stdout": null, "expected_stderr": null },
          { "command": "cat xx* | cksum", "expected_exit": 0, "expected_stdout": null, "expected_stderr": null }
        ],
        "ignore_fields": {
          "ignore_exit_code": false,
          "ignore_stdout": false,
          "ignore_stderr": false,
          "ignore_verifications": false
        }
      },
      "cleanup_commands": ["rm -f in xx*"]
    },
