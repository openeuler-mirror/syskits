{
  "tests": [
    {
      "command": "csplit",
      "description": "csplit.sh: regexp split and fixed line split",
      "args": ["in", "/^$/", "2"],
      "setup_commands": [
        "(echo a; echo; echo) > in"
      ],
      "expectation": {
        "execution": { "exit_code": 0, "stdout": "", "stderr": "" },
        "verifications": [
          { "command": "test -f xx00 && test -f xx01 && test -f xx02", "expected_exit": 0, "expected_stdout": null, "expected_stderr": null },
          { "command": "printf '\n\n' > exp && cmp -s xx02 exp", "expected_exit": 0, "expected_stdout": null, "expected_stderr": null },
          { "command": "wc -c xx00 xx01 xx02", "expected_exit": 0, "expected_stdout": null, "expected_stderr": null }
        ],
        "ignore_fields": {
          "ignore_exit_code": false,
          "ignore_stdout": false,
          "ignore_stderr": false,
          "ignore_verifications": false
        }
      },
      "cleanup_commands": ["rm -f in exp xx*"]
    },
    {
      "command": "csplit",
      "description": "csplit.sh: /a/-1 with {*} should terminate and match coreutils",
      "args": ["in", "/a/-1", "{*}"],
      "setup_commands": [
        "(echo; echo a) > in"
      ],
      "expectation": {
        "execution": { "exit_code": 0, "stdout": "", "stderr": "" },
