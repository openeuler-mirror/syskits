{
    "tests": [
        {
            "command": "csplit",
            "description": "csplit: 按照行号来切分",
            "args": [
                "csplit_input.txt",
                "3"
            ],
            "setup_commands": [
                "seq 1 10 > csplit_input.txt"
            ],
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": "4\n17\n",
                    "stderr": ""
                },
                "verifications": [
                    {
                        "command": "ls xx* | wc -l",
                        "expected_exit": 0,
                        "expected_stdout": "",
                        "expected_stderr": null
                    },
                    {
                        "command": "cat xx*",
                        "expected_exit": 0,
                        "expected_stdout": "",
                        "expected_stderr": null
                    }
                ],
                "ignore_fields": {
                    "ignore_exit_code": false,
                    "ignore_stdout": false,
                    "ignore_stderr": false,
                    "ignore_function": false
                }
            },
            "cleanup_commands": [
                "rm -f csplit_input.txt xx*"
            ]
        },
