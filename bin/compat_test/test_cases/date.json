{
  "tests": [
    {
      "tstdin": "",
      "command": "date",
      "description": "基本功能测试 - 显示当前日期",
      "args": [],
      "expectation": {
        "execution": {
          "exit_code": 0,
          "stdout": "",
          "stderr": ""
        },
        "verifications": [
          {
            "command": "date | grep -E '\\w{3}\\s+\\w{3}\\s+\\d{1,2}\\s+\\d{2}:\\d{2}:\\d{2}\\s+CST\\s+\\d{4}'",
            "expected_exit": 0
          }
        ]
      },
      "cleanup_commands": []
    },
    {
      "tstdin": "",
      "command": "date",
      "description": "日期解析 - next Friday",
      "args": ["-d", "next Friday"],
      "expectation": {
        "execution": {
          "exit_code": 0,
          "stdout": "",
          "stderr": ""
        },
        "verifications": [
          {
            "command": "date -d 'next Friday' | grep -E 'Fri\\s+Aug\\s+1\\s+00:00:00\\s+CST\\s+2025'",
            "expected_exit": 0
          }
        ]
      },
      "cleanup_commands": []
    },
