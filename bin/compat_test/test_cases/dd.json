            "description": "dd: 基本拷贝",
            "args": [
                "of=test_dd_output"
            ],
            "setup_commands": [
            ],
            "expectation": {
                "execution": {
                "exit_code": 0,
                "stdout": "",
                "stderr": ""
                },
                "verifications": [
                {
                    "command": "cat test_dd_output",
                    "expected_exit": 0,
                    "expected_stdout": "hello",
                    "expected_stderr": null
                }
                ],
                "ignore_fields": {
                "ignore_exit_code": false,
                "ignore_stdout": false,
                "ignore_stderr": false,
                "ignore_function": false
                }
            },
            "cleanup_commands": [
                "rm -f test_dd_output"
            ]
        },
