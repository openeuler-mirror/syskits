            "setup_commands": [],
            "args": [],
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": "文件系统                   1K的块     已用     可用 已用% 挂载点\n/dev/mapper/ctyunos-root 71923932 26996308 41884732   40% /\ndevtmpfs                     4096        0     4096    0% /dev\ntmpfs                     7910672        0  7910672    0% /dev/shm\ntmpfs                        4096        0     4096    0% /sys/fs/cgroup\ntmpfs                     3164272     9232  3155040    1% /run\ntmpfs                     7910676        0  7910676    0% /tmp\n/dev/sda2                  996780   284236   643732   31% /boot\n",
