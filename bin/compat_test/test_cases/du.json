        {
            "tstdin": "",
            "command": "du",
            "description": "du: 使用 --exclude 排除匹配的文件",
            "setup_commands": [
                "mkdir /test_du_du_exclude",
                "touch /test_du_du_exclude/a.txt",
                "echo 'hello' > /test_du_du_exclude/b.log",
                "mkdir /test_du_du_exclude/subdir",
                "echo 'world' > /test_du_du_exclude/subdir/c.log",
                "touch /test_du_du_exclude/subdir/d.txt"
            ],
            "args": [
                "-a",
                "--exclude=*.log",
                "/test_du_du_exclude"
            ],
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": "0   /test_du_du_exclude/a.txt\n0    /test_du_du_exclude/subdir/d.txt\n4     /test_du_du_exclude/subdir\n8   /test_du_du_exclude\n",
                    "stderr": ""
                }
            },
            "cleanup_commands": [
                "rm -rf /test_du_du_exclude"
            ]
        },
        {
