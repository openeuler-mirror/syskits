                "ln /test_du_du_hardlink/origin.txt /test_du_du_hardlink/hardlink2"
            ],
            "args": [
                "/test_du_du_hardlink/origin.txt",
                "/test_du_du_hardlink/hardlink1",
                "/test_du_du_hardlink/hardlink2"
