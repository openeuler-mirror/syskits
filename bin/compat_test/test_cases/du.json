{
    "tests": [
        {
            "tstdin": "",
            "command": "du",
            "description": "du: 基本用法：统计指定目录",
            "setup_commands": [
                "mkdir /test_du_du_basic1",
                "touch /test_du_du_basic1/a.txt",
                "touch /test_du_du_basic1/b.txt",
                "touch /test_du_du_basic1/c.txt",
                "touch /test_du_du_basic1/.hidden",
                "mkdir /test_du_du_basic1/subdir",
                "touch /test_du_du_basic1/subdir/d.txt"
            ],
            "args": [
                "/test_du_du_basic1"
            ],
            "expectation": {
                "execution": {
                "exit_code": 0,
                "stdout": "4   /test_du_du_basic1/subdir\n8     /test_du_du_basic1\n",
                "stderr": ""
                }
            },
            "cleanup_commands": [
                "rm -rf /test_du_du_basic1"
            ]
        },
        {
            "tstdin": "",
            "command": "du",
            "description": "du: 同时指定多个路径",
            "setup_commands": [
                "mkdir /test_du_du_basic2",
                "touch /test_du_du_basic2/a.txt",
                "touch /test_du_du_basic2/b.txt",
                "echo 'hello' > /test_du_du_basic2/c.txt",
                "touch /test_du_du_basic2/.hidden",
                "mkdir /test_du_du_basic2/subdir",
                "touch /test_du_du_basic2/subdir/d.txt"
            ],
            "args": [
                "/test_du_du_basic2/b.txt",
                "/test_du_du_basic2/subdir",
                "/test_du_du_basic2/c.txt"
            ],
            "expectation": {
                "execution": {
                "exit_code": 0,
                "stdout": "0   /test_du_du_basic2/b.txt\n4      /test_du_du_basic2/subdir\n4     /test_du_du_basic2/c.txt\n",
                "stderr": ""
                }
            },
            "cleanup_commands": [
                "rm -rf /test_du_du_basic2"
            ]
        },
