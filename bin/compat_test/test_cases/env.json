{
    "tests": [
        {
            "command": "env",
            "description": "Basic env with no arguments - print environment",
            "args": [],
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": null,
                    "stderr": ""
                },
                "verifications": [
                    {
                        "command": "test -n \"$CMD_STDOUT\"",
                        "expected_exit": 0
                    }
                ]
            }
        },
        {
            "command": "env",
            "description": "Clear environment with -i",
            "args": ["-i"],
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": "",
                    "stderr": ""
                }
            }
        },
        {
            "command": "env",
            "description": "Clear environment with --ignore-environment",
            "args": ["--ignore-environment"],
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": "",
                    "stderr": ""
                }
            }
        },
        {
            "command": "env",
            "description": "Clear environment with - (dash)",
            "args": ["-"],
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": "",
                    "stderr": ""
                }
            }
        },
        {
            "command": "env",
            "description": "Set environment variable",
            "args": ["-i", "TEST_VAR=test_value"],
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": "TEST_VAR=test_value\n",
                    "stderr": ""
                }
            }
        },
        {
            "command": "env",
            "description": "Set multiple environment variables",
            "args": ["-i", "VAR1=value1", "VAR2=value2"],
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": null,
                    "stderr": ""
                },
                "verifications": [
                    {
                        "command": "echo \"$CMD_STDOUT\" | grep -q 'VAR1=value1'",
                        "expected_exit": 0
                    },
                    {
                        "command": "echo \"$CMD_STDOUT\" | grep -q 'VAR2=value2'",
                        "expected_exit": 0
                    }
                ]
            }
        },
        {
            "command": "env",
            "description": "Unset environment variable with -u",
            "setup_commands": ["export TEST_UNSET=value"],
            "args": ["-u", "TEST_UNSET"],
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": null,
                    "stderr": ""
                },
                "verifications": [
                    {
                        "command": "echo \"$CMD_STDOUT\" | grep -q 'TEST_UNSET' && exit 1 || exit 0",
                        "expected_exit": 0
                    }
                ]
            },
            "cleanup_commands": ["unset TEST_UNSET"]
        },
        {
            "command": "env",
            "description": "Multiple -u options to unset multiple variables",
            "setup_commands": ["export VAR_A=a", "export VAR_B=b"],
            "args": ["-u", "VAR_A", "-u", "VAR_B"],
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": null,
                    "stderr": ""
                },
                "verifications": [
                    {
                        "command": "echo \"$CMD_STDOUT\" | grep -q 'VAR_A' && exit 1 || exit 0",
                        "expected_exit": 0
                    },
                    {
                        "command": "echo \"$CMD_STDOUT\" | grep -q 'VAR_B' && exit 1 || exit 0",
                        "expected_exit": 0
                    }
                ]
            },
            "cleanup_commands": ["unset VAR_A VAR_B"]
        },
        {
            "command": "env",
            "description": "Execute simple command",
            "args": ["echo", "hello"],
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": "hello\n",
                    "stderr": ""
                }
            }
        },
        {
            "command": "env",
            "description": "Execute command with environment variable",
            "args": ["-i", "TEST_VAR=test", "sh", "-c", "echo $TEST_VAR"],
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": "test\n",
                    "stderr": ""
                }
            }
        },
        {
            "command": "env",
            "description": "Set variable and execute shell command",
            "args": ["FOO=bar", "sh", "-c", "echo $FOO"],
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": "bar\n",
                    "stderr": ""
                }
            }
        },
        {
            "command": "env",
            "description": "Test exit code propagation (exit 0)",
            "args": ["sh", "-c", "exit 0"],
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": "",
                    "stderr": ""
                }
            }
        },
        {
            "command": "env",
            "description": "Test exit code propagation (exit 1)",
            "args": ["sh", "-c", "exit 1"],
            "expectation": {
                "execution": {
                    "exit_code": 1,
                    "stdout": "",
                    "stderr": ""
                }
            }
        },
        {
            "command": "env",
            "description": "Test exit code propagation (exit 2)",
            "args": ["sh", "-c", "exit 2"],
            "expectation": {
                "execution": {
                    "exit_code": 2,
                    "stdout": "",
                    "stderr": ""
                }
            }
        },
        {
            "command": "env",
            "description": "Test exit code propagation (exit 125)",
            "args": ["sh", "-c", "exit 125"],
            "expectation": {
                "execution": {
                    "exit_code": 125,
                    "stdout": "",
                    "stderr": ""
                }
            }
        },
        {
            "command": "env",
            "description": "Test command not found (exit 127)",
            "args": ["nonexistent_command_12345"],
            "expectation": {
                "execution": {
                    "exit_code": 127,
                    "stdout": "",
                    "stderr": null
                }
            }
        },
        {
            "command": "env",
            "description": "Test command not executable (exit 126)",
            "args": ["./nonexec_file"],
            "setup_commands": ["touch nonexec_file", "chmod -x nonexec_file"],
            "expectation": {
                "execution": {
                    "exit_code": 126,
                    "stdout": "",
                    "stderr": null
                },
                "verifications": [
                    {
                        "command": "echo \"$CMD_STDERR\" | grep -q -i 'permission denied'",
                        "expected_exit": 0
                    }
                ]
            },
            "cleanup_commands": ["rm -f nonexec_file"]
        },
        {
            "command": "env",
            "description": "Test --chdir option",
            "setup_commands": ["mkdir -p /tmp/test_env_chdir"],
            "args": ["--chdir=/tmp/test_env_chdir", "pwd"],
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": "/tmp/test_env_chdir\n",
                    "stderr": ""
                }
            },
            "cleanup_commands": ["rm -rf /tmp/test_env_chdir"]
        },
        {
            "command": "env",
            "description": "Test -C option (short form)",
            "setup_commands": ["mkdir -p /tmp/test_env_chdir2"],
            "args": ["-C", "/tmp/test_env_chdir2", "pwd"],
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": "/tmp/test_env_chdir2\n",
                    "stderr": ""
                }
            },
            "cleanup_commands": ["rm -rf /tmp/test_env_chdir2"]
        },
        {
            "command": "env",
            "description": "Test -0 (null-terminated output)",
            "args": ["-0", "-i", "A=1", "B=2"],
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": "A=1\u0000B=2\u0000",
                    "stderr": ""
                }
            }
        },
        {
            "command": "env",
            "description": "Test -S (split string)",
            "args": ["-S", "A=1 B=2", "env"],
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": null,
                    "stderr": ""
                },
                "verifications": [
                    {
                        "command": "echo \"$CMD_STDOUT\" | grep -q 'A=1'",
                        "expected_exit": 0
                    },
                    {
                        "command": "echo \"$CMD_STDOUT\" | grep -q 'B=2'",
                        "expected_exit": 0
                    }
                ]
            }
        },
        {
            "command": "env",
            "description": "Test -- to end options",
            "args": ["--", "echo", "test"],
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": "test\n",
                    "stderr": ""
                }
            }
        },
        {
            "command": "env",
            "description": "Test setting variable with empty value",
            "args": ["-i", "EMPTY_VAR="],
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": "EMPTY_VAR=\n",
                    "stderr": ""
                }
            }
        },
        {
            "command": "env",
            "description": "Test combining -i and variable assignment",
            "args": ["-i", "--", "VAR=value"],
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": "VAR=value\n",
                    "stderr": ""
                }
            }
        },
        {
            "command": "env",
            "description": "Error: invalid option",
            "args": ["---"],
            "expectation": {
                "execution": {
                    "exit_code": 125,
                    "stdout": "",
                    "stderr": null
                }
            }
        },
        {
            "command": "env",
            "description": "Error: missing option argument for -u",
            "args": ["-u"],
            "expectation": {
                "execution": {
                    "exit_code": 125,
                    "stdout": "",
                    "stderr": null
                }
            }
        },
        {
            "command": "env",
            "description": "Error: -u with invalid variable name (contains =)",
            "args": ["-u", "a=b", "true"],
            "expectation": {
                "execution": {
                    "exit_code": 125,
                    "stdout": "",
                    "stderr": null
                }
            }
        },
        {
            "command": "env",
            "description": "Error: -u with empty variable name",
            "args": ["-u", "", "true"],
            "expectation": {
                "execution": {
                    "exit_code": 125,
                    "stdout": "",
                    "stderr": null
                }
            }
        },
        {
            "command": "env",
            "description": "Error: --chdir with nonexistent directory",
            "args": ["--chdir=/nonexistent_dir_12345", "true"],
            "expectation": {
                "execution": {
                    "exit_code": 125,
                    "stdout": "",
                    "stderr": null
                }
            }
        },
        {
            "command": "env",
            "description": "Error: -C without command",
            "setup_commands": ["mkdir -p /tmp/test_env_chdir3"],
            "args": ["-C", "/tmp/test_env_chdir3"],
            "expectation": {
                "execution": {
                    "exit_code": 125,
                    "stdout": "",
                    "stderr": null
                },
                "verifications": [
                    {
                        "command": "echo \"$CMD_STDERR\" | grep -q 'must specify command'",
                        "expected_exit": 0
                    }
                ]
            },
            "cleanup_commands": ["rm -rf /tmp/test_env_chdir3"]
        },
        {
            "command": "env",
            "description": "Error: -0 with command",
            "args": ["-0", "ls"],
            "expectation": {
                "execution": {
                    "exit_code": 125,
                    "stdout": "",
                    "stderr": null
                },
                "verifications": [
                    {
                        "command": "echo \"$CMD_STDERR\" | grep -q -i 'cannot specify --null (-0) with command'",
                        "expected_exit": 0
                    }
                ]
            }
        },
        {
            "command": "env",
            "description": "Test --help flag",
            "args": ["--help"],
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": null,
                    "stderr": ""
                },
                "verifications": [
                    {
                        "command": "echo \"$CMD_STDOUT\" | grep -q -i 'usage\\|用法'",
                        "expected_exit": 0
                    }
                ]
            }
        },
        {
            "command": "env",
            "description": "Test --version flag",
            "args": ["--version"],
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": null,
                    "stderr": ""
                },
                "verifications": [
                    {
                        "command": "echo \"$CMD_STDOUT\" | grep -q 'env'",
                        "expected_exit": 0
                    }
                ]
            }
        }
    ]
}
