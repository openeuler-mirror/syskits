    },
    {
      "tstdin": "",
      "command": "fmt",
      "description": "fmt: 自定义窄宽度 -w 7（已知差异跟踪）",
      "setup_commands": [
        "printf 'ab cde fg\\n' > in.txt"
      ],
      "args": ["-w", "7", "in.txt"],
      "expectation": {
        "execution": {
          "exit_code": 0,
          "stdout": "",
          "stderr": ""
