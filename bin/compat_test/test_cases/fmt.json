      "expectation": {
        "execution": {
          "exit_code": 1,
          "stdout": "",
          "stderr": ""
        }
      },
      "cleanup_commands": []
    },
    {
      "tstdin": "",
      "command": "fmt",
      "description": "fmt(base.pl): 8-bit-pfx",
      "setup_commands": [
        "cat > in.txt <<'EOT'\nça\nçb\nEOT"
