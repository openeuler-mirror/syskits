{
  "tests": [
    {
      "tstdin": "",
      "command": "fmt",
      "description": "fmt: 默认重排（基础场景）",
      "setup_commands": [
        "cat > in.txt <<'EOT'\nThis is a very long line of text that is intentionally written to exceed the default line width used by the fmt command so that we can verify whether it correctly wraps the line without breaking words.\nEOT"
      ],
      "args": ["in.txt"],
      "expectation": {
        "execution": {
          "exit_code": 0,
          "stdout": "",
          "stderr": ""
        }
      },
      "cleanup_commands": ["rm -f in.txt"]
    },
    {
      "tstdin": "",
      "command": "fmt",
      "description": "fmt: 旧式 -WIDTH 语法（首参数）",
      "setup_commands": [
        "cat > in.txt <<'EOT'\nalpha beta gamma delta epsilon zeta eta theta iota kappa lambda\nEOT"
      ],
      "args": ["-72", "in.txt"],
      "expectation": {
        "execution": {
          "exit_code": 0,
          "stdout": "",
          "stderr": ""
        }
      },
      "cleanup_commands": ["rm -f in.txt"]
    },
    {
      "tstdin": "",
      "command": "fmt",
      "description": "fmt(base.pl): wide-1 -w 32768",
      "setup_commands": [],
      "args": ["-w", "32768"],
      "expectation": {
        "execution": {
          "exit_code": 1,
          "stdout": "",
          "stderr": ""
        }
      },
      "cleanup_commands": []
    },
    {
      "tstdin": "",
      "command": "fmt",
      "description": "fmt(base.pl): wide-2 -w 2147483647",
      "setup_commands": [],
      "args": ["-w", "2147483647"],
      "expectation": {
        "execution": {
          "exit_code": 1,
          "stdout": "",
          "stderr": ""
        }
      },
      "cleanup_commands": []
    },
    {
      "tstdin": "",
      "command": "fmt",
      "description": "fmt(base.pl): bad-suffix -72x",
      "setup_commands": [],
      "args": ["-72x"],
      "expectation": {
        "execution": {
          "exit_code": 1,
          "stdout": "",
          "stderr": ""
        }
      },
      "cleanup_commands": []
    },
    {
      "tstdin": "",
      "command": "fmt",
      "description": "fmt(base.pl): no-file",
      "setup_commands": [],
      "args": ["no-such-file"],
      "expectation": {
        "execution": {
          "exit_code": 1,
          "stdout": "",
          "stderr": ""
        }
      },
      "cleanup_commands": []
    },
    {
      "tstdin": "",
      "command": "fmt",
      "description": "fmt: 部分文件不存在（应继续处理其余文件并返回1）",
      "setup_commands": [
        "echo 'hello from file one' > file1.txt",
        "echo 'hello from file two' > file2.txt"
      ],
      "args": ["file1.txt", "missing.txt", "file2.txt"],
      "expectation": {
        "execution": {
          "exit_code": 1,
          "stdout": "",
          "stderr": ""
        }
      },
      "cleanup_commands": ["rm -f file1.txt file2.txt"]
    },
    {
      "tstdin": "",
      "command": "fmt",
      "description": "fmt(base.pl): obs-1 -c -72",
