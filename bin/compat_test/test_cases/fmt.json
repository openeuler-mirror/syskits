    {
      "tstdin": "",
      "command": "fmt",
      "description": "fmt(goal-option.sh): -g 60 -w 72",
      "setup_commands": [
        "cat > base.txt <<'EOT'\n@command{fmt} prefers breaking lines at the end of a sentence, and tries to\navoid line breaks after the first word of a sentence or before the last word\nof a sentence.  A @dfn{sentence break} is defined as either the end of a\nparagraph or a word ending in any of @samp{.?!}, followed by two spaces or end\nof line, ignoring any intervening parentheses or quotes.  Like @TeX{},\n@command{fmt} reads entire ''paragraphs'' before choosing line breaks; the\nalgorithm is a variant of that given by\nDonald E. Knuth and Michael F. Plass\nin ''Breaking Paragraphs Into Lines'',\n@cite{Software---Practice & Experience}\n@b{11}, 11 (November 1981), 1119--1184.\nEOT"
      ],
      "args": ["-g", "60", "-w", "72", "base.txt"],
      "expectation": {
        "execution": {
          "exit_code": 0,
          "stdout": "",
          "stderr": ""
        }
      },
      "cleanup_commands": ["rm -f base.txt"]
    },
    {
      "tstdin": "",
      "command": "fmt",
      "description": "fmt(long-line.sh): -s 长行拆分",
      "setup_commands": [
        "printf '%2030s\\n' ' ' | sed 's/../ y/g' > in.txt"
      ],
      "args": ["-s", "in.txt"],
      "expectation": {
        "execution": {
          "exit_code": 0,
          "stdout": "",
          "stderr": ""
        }
      },
      "cleanup_commands": ["rm -f in.txt"]
    },
    {
      "tstdin": "=\u00A0=",
      "command": "fmt",
