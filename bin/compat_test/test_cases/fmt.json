    },
    {
      "tstdin": "",
      "command": "fmt",
      "description": "fmt: 缩进段落（已知差异跟踪）",
      "setup_commands": [
        "cat > in.txt <<'EOT'\n    This is a very long line of text that is intentionally written to exceed the default line width used by the fmt command so that we can verify whether it correctly wraps the line without breaking words.\n   this is second line.\n   this is third line.\nEOT"
      ],
      "args": ["in.txt"],
      "expectation": {
        "execution": {
          "exit_code": 0,
          "stdout": "",
          "stderr": ""
        }
      },
      "cleanup_commands": ["rm -f in.txt"]
    }
  ]
}
