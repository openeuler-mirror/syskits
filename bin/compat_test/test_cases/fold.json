{
    "tests": [
        {
            "tstdin": "",
            "command": "fold",
            "description": "测试默认宽度处理",
            "args": [
                "input.txt"
            ],
            "setup_commands": [
                "echo 'This is a test file for fold command. It contains spaces and long lines to test wrapping.' > input.txt"
            ],
            "cleanup_commands": [
                "rm -f input.txt"
            ],
            "expectation": {
                "execution": {
                    "exit_code": 0
                },
                "verifications": [
                    {
                        "command": "test $(wc -L < input.txt) -le 80",
                        "expected_exit": 0
                    }
                ]
            }
        },
        {
            "tstdin": "",
            "command": "fold",
            "description": "测试指定宽度20列",
            "args": [
                "-w",
                "20",
                "input.txt"
            ],
            "setup_commands": [
                "echo 'This is a test file for fold command. It contains spaces and long lines to test wrapping.' > input.txt"
            ],
            "cleanup_commands": [
                "rm -f input.txt"
            ],
            "expectation": {
                "execution": {
                    "exit_code": 0
                },
                "verifications": [
                    {
                        "command": "test $(wc -L < input.txt) -le 20",
                        "expected_exit": 0
                    }
                ]
            }
        },
        {
            "tstdin": "",
            "command": "fold",
            "description": "测试空格处换行",
            "args": [
                "-s",
                "-w",
                "15",
                "input.txt"
            ],
            "setup_commands": [
                "echo 'This is a very long line that should be split at spaces.' > input.txt"
            ],
            "cleanup_commands": [
                "rm -f input.txt"
            ],
            "expectation": {
                "execution": {
                    "exit_code": 0
                },
                "verifications": [
                    {
                        "command": "test $(wc -L < input.txt) -le 15",
                        "expected_exit": 0
                    },
                    {
                        "command": "grep -q '[^ ]$' input.txt",
                        "expected_exit": 0
                    }
                ]
            }
        },
