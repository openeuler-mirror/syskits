    {
      "tstdin": "",
      "command": "install",
      "description": "--preserve-context (warn if unsupported)",
      "args": ["--preserve-context", "a", "b"],
      "setup_commands": [
        "printf 'test\n' > a"
      ],
      "expectation": {
        "execution": {
          "exit_code": 0,
          "stdout": "",
          "stderr": null
