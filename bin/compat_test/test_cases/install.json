            "expected_exit": 0
          }
        ]
      }
    },
    {
      "tstdin": "",
      "command": "install",
      "description": "-D -v: create leading components",
      "args": ["-D", "-v", "file", "sub3/a/b/c/file"],
      "setup_commands": [
        "printf 'foo\n' > file"
      ],
      "expectation": {
        "execution": {
          "exit_code": 0,
          "stdout": "install: creating directory 'sub3'\ninstall: creating directory 'sub3/a'\ninstall: creating directory 'sub3/a/b'\ninstall: creating directory 'sub3/a/b/c'\n'file' -> 'sub3/a/b/c/file'\n",
          "stderr": ""
        },
        "verifications": [
          {
            "command": "test -f sub3/a/b/c/file",
            "expected_exit": 0
          }
        ]
      }
    },
    {
      "tstdin": "",
      "command": "install",
      "description": "-t -D -v: create target directory hierarchy",
      "args": ["-t", "sub4/a/b/c", "-D", "-v", "file"],
      "setup_commands": [
        "printf 'foo\n' > file"
      ],
      "expectation": {
        "execution": {
          "exit_code": 0,
          "stdout": "install: creating directory 'sub4'\ninstall: creating directory 'sub4/a'\ninstall: creating directory 'sub4/a/b'\ninstall: creating directory 'sub4/a/b/c'\n'file' -> 'sub4/a/b/c/file'\n",
          "stderr": ""
        },
        "verifications": [
          {
            "command": "test -f sub4/a/b/c/file",
            "expected_exit": 0
          }
        ]
      }
    },
    {
      "tstdin": "",
      "command": "install",
      "description": "-t -D: existing file is not directory",
      "args": ["-t", "sub4/file_exists", "-D", "-v", "file"],
      "setup_commands": [
        "mkdir -p sub4",
        "touch sub4/file_exists",
        "printf 'foo\n' > file"
      ],
      "expectation": {
        "execution": {
          "exit_code": 1,
          "stdout": "",
          "stderr": "install: failed to access 'sub4/file_exists': Not a directory\n"
        }
      }
    },
    {
