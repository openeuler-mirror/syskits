        "verifications": [
          {
            "command": "if selinuxenabled 2>/dev/null; then exit 0; else test \"$CMD_STDERR\" = \"install: WARNING: ignoring --preserve-context; this kernel is not SELinux-enabled\\n\"; fi",
            "expected_exit": 0
          }
        ]
      }
    },
    {
      "tstdin": "",
      "command": "install",
