{
  "tests": [
    {
      "tstdin": "",
      "command": "install",
      "description": "basic: install file into directory",
      "args": ["file", "dir"],
      "setup_commands": [
        "mkdir -p dir",
        "printf 'foo\n' > file"
      ],
      "expectation": {
        "execution": {
          "exit_code": 0,
          "stdout": "",
          "stderr": ""
        },
        "verifications": [
          {
            "command": "test -f file && test -f dir/file",
            "expected_exit": 0
          }
        ]
      }
    },
    {
      "tstdin": "",
      "command": "install",
      "description": "verbose: install file into directory",
      "args": ["-v", "file", "dir"],
      "setup_commands": [
        "mkdir -p dir",
        "printf 'foo\n' > file"
      ],
      "expectation": {
        "execution": {
          "exit_code": 0,
          "stdout": "'file' -> 'dir/file'\n",
          "stderr": ""
        },
        "verifications": [
          {
            "command": "test -f dir/file",
            "expected_exit": 0
          }
        ]
      }
    },
    {
      "tstdin": "",
      "command": "install",
      "description": "-d: create directory",
      "args": ["-d", "newdir"],
      "expectation": {
        "execution": {
          "exit_code": 0,
          "stdout": "",
          "stderr": ""
        },
        "verifications": [
          {
            "command": "test -d newdir",
            "expected_exit": 0
          }
        ]
      }
    },
    {
