    {
      "tstdin": "",
      "command": "install",
      "description": "-p: preserve timestamps",
      "args": ["-p", "a", "b"],
      "setup_commands": [
        "printf 'test\n' > a",
        "touch -t 202001010101.01 a"
      ],
      "expectation": {
        "execution": {
          "exit_code": 0,
          "stdout": "",
          "stderr": ""
        },
        "verifications": [
          {
            "command": "test \"$(stat -c %Y a)\" = \"$(stat -c %Y b)\"",
            "expected_exit": 0
          }
        ]
      }
    },
    {
      "tstdin": "",
      "command": "install",
      "description": "-s --strip-program: custom strip",
      "args": ["src", "dest", "-s", "--strip-program=./b"],
      "setup_commands": [
        "cat <<'SH' > b\n#!/bin/sh\nsed s/b/B/ \"$1\" > \"$1.t\" && mv \"$1.t\" \"$1\"\nSH",
        "chmod +x b",
        "printf 'abc\n' > src",
        "printf 'aBc\n' > exp"
      ],
      "expectation": {
        "execution": {
          "exit_code": 0,
          "stdout": "",
          "stderr": ""
        },
        "verifications": [
          {
            "command": "cmp -s exp dest",
            "expected_exit": 0
          }
        ]
      }
    },
    {
      "tstdin": "",
      "command": "install",
      "description": "-s --strip-program failure removes dest",
      "args": ["src", "dest2", "-s", "--strip-program=./FOO"],
      "setup_commands": [
        "printf 'abc\n' > src"
      ],
      "expectation": {
        "execution": {
          "exit_code": 1,
          "stdout": "",
          "stderr": null
        },
        "verifications": [
          {
            "command": "test ! -e dest2",
            "expected_exit": 0
          }
        ]
      }
    },
    {
      "tstdin": "",
      "command": "install",
      "description": "-s --strip-program: no naked hyphen",
      "args": ["-s", "--strip-program=./no-hyphen", "--", "src", "-dest"],
      "setup_commands": [
        "cat <<'SH' > no-hyphen\n#!/bin/sh\nprintf -- '%s\\n' \"$1\" | grep '^[^-]'\nSH",
        "chmod +x no-hyphen",
        "printf 'abc\n' > src"
      ],
      "expectation": {
        "execution": {
          "exit_code": 0,
          "stdout": "",
          "stderr": ""
        },
        "verifications": [
          {
            "command": "test -f -dest",
            "expected_exit": 0
          }
        ]
      }
    },
    {
      "tstdin": "",
