    },
    {
      "tstdin": "",
      "command": "install",
      "description": "--strip-program without -s warns",
      "args": ["--strip-program=./b", "a", "dest"],
      "setup_commands": [
        "cat <<'SH' > b\n#!/bin/sh\nexit 0\nSH",
        "chmod +x b",
        "printf 'abc\n' > a"
      ],
      "expectation": {
        "execution": {
          "exit_code": 0,
          "stdout": "",
          "stderr": "install: WARNING: ignoring --strip-program option as -s option was not specified\n"
        },
        "verifications": [
          {
            "command": "test -f dest",
            "expected_exit": 0
          }
        ]
      }
    },
    {
      "tstdin": "",
