    {
      "tstdin": "",
      "command": "install",
      "description": "-C -v with symlinks",
      "args": ["-C", "-v", "-m0644", "c", "d"],
      "setup_commands": [
        "printf 'test\n' > a",
        "printf 'test\n' > b",
        "ln -s a c",
        "ln -s b d"
      ],
      "expectation": {
        "execution": {
          "exit_code": 0,
          "stdout": "removed 'd'\n'c' -> 'd'\n",
          "stderr": ""
        }
      }
