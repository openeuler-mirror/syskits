        "echo 'test content' > /tmp/test_install_basic/source.txt"
      ],
      "args": ["/tmp/test_install_basic/source.txt", "/tmp/test_install_basic/dest.txt"],
      "expectation": {
        "execution": {
          "exit_code": 0,
          "stdout": "",
          "stderr": ""
        },
        "verifications": [
          {
            "command": "test -f /tmp/test_install_basic/dest.txt",
            "expected_exit": 0
          },
          {
            "command": "test -f /tmp/test_install_basic/source.txt",
            "expected_exit": 0
          },
          {
            "command": "diff /tmp/test_install_basic/source.txt /tmp/test_install_basic/dest.txt",
            "expected_exit": 0
          }
        ]
      },
      "cleanup_commands": [
        "rm -rf /tmp/test_install_basic"
      ]
    },
