            "command": "kill",
            "description": "无参数调用 - 应失败并提示缺少进程 ID (退出码1)",
            "args": [],
            "expectation": {
                "execution": {
                    "exit_code": 1,
                    "stdout": null,
                    "stderr": null
                },
                "ignore_fields": {
                    "ignore_stdout": true,
                    "ignore_stderr": true
                }
            },
            "env": {
                "SYSKITS_KILL_MODE": "util-linux"
            }
        },
