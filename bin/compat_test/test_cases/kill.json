{
  "tests": [
    {
      "command": "kill",
      "description": "无参数调用应显示 usage 并返回 2",
      "args": [],
      "expectation": {
        "execution": {
          "exit_code": 2,
          "stdout": "",
          "stderr": null
        },
        "ignore_fields": {
          "ignore_stderr": true
        }
      },
      "compareUseBash": true
    },
    {
      "command": "kill",
      "description": "仅指定信号无 pid，返回 2",
      "args": ["-TERM"],
      "expectation": {
        "execution": {
          "exit_code": 2,
          "stdout": "",
          "stderr": null
        },
        "ignore_fields": {
          "ignore_stderr": true
        }
      },
      "compareUseBash": true
    },
    {
      "command": "kill",
      "description": "-l 列出信号（bash 格式）",
      "args": ["-l"],
      "expectation": {
        "execution": {
          "exit_code": 0,
          "stdout": null,
          "stderr": ""
        },
        "verifications": [
          {
            "command": "echo \"$CMD_STDOUT\" | grep -q SIGIO",
            "expected_exit": 0
          },
          {
            "command": "echo \"$CMD_STDOUT\" | grep -q SIGTERM",
            "expected_exit": 0
          }
        ],
        "ignore_fields": {
          "ignore_stdout": true
        }
      },
      "compareUseBash": true
    },
    {
      "command": "kill",
      "description": "-L 是 -l 的同义选项",
      "args": ["-L"],
      "expectation": {
        "execution": {
          "exit_code": 0,
          "stdout": null,
          "stderr": ""
        },
        "verifications": [
          {
            "command": "echo \"$CMD_STDOUT\" | grep -q SIGIO",
            "expected_exit": 0
          }
        ],
        "ignore_fields": {
          "ignore_stdout": true
        }
      },
      "compareUseBash": true
    },
