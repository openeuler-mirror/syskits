        {
            "tstdin": "",
            "command": "ls",
            "description": "错误情况 - 不存在的目录",
            "setup_commands": [],
            "args": ["nonexistent"],
            "expectation": {
                "execution": {
                    "exit_code": 2,
                    "stdout": "",
                    "stderr": "ls: cannot access 'nonexistent': No such file or directory"
                }
            },
            "cleanup_commands": []
        },
        {
            "tstdin": "",
            "command": "ls",
            "description": "测试 C locale 下的文件名排序（字节比较）",
            "setup_commands": [
                "mkdir -p test_locale_dir",
                "touch test_locale_dir/Windows",
                "touch test_locale_dir/linux",
                "touch test_locale_dir/windows",
                "touch test_locale_dir/Apple"
            ],
            "args": ["test_locale_dir"],
            "env": {
                "LC_COLLATE": "C"
            },
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": "Apple\nWindows\nlinux\nwindows",
                    "stderr": ""
                }
            },
            "cleanup_commands": [
                "rm -rf test_locale_dir"
            ]
        },
        {
