{
  "tests": [
    {
      "command": "mknod",
      "description": "Help: --help flag",
      "args": ["--help"],
      "expectation": {
        "execution": {
          "exit_code": 0,
          "stdout": null,
          "stderr": ""
        },
        "verifications": [
          {
            "command": "echo \"$CMD_STDOUT\" | grep -q -i \"mknod\\|usage\\|用法\"",
            "expected_exit": 0
          }
        ]
      }
    },
    {
      "command": "mknod",
      "description": "Version: --version flag",
      "args": ["--version"],
      "expectation": {
        "execution": {
          "exit_code": 0,
          "stdout": null,
          "stderr": ""
        },
        "verifications": [
          {
            "command": "echo \"$CMD_STDOUT\" | grep -q -E \"[0-9]+\\.[0-9]+\"",
            "expected_exit": 0
          }
        ]
      }
    },
    {
      "command": "mknod",
      "description": "Basic: create FIFO without mode",
      "setup_commands": [
        "rm -f /tmp/test_mknod_fifo1"
      ],
      "args": ["/tmp/test_mknod_fifo1", "p"],
      "expectation": {
        "execution": {
          "exit_code": 0,
          "stdout": "",
          "stderr": ""
        },
        "verifications": [
          {
            "command": "test -p /tmp/test_mknod_fifo1",
            "expected_exit": 0
          }
        ]
      },
      "cleanup_commands": [
        "rm -f /tmp/test_mknod_fifo1"
      ]
    },
    {
      "command": "mknod",
      "description": "Mode: create FIFO with -m 644",
      "setup_commands": [
        "rm -f /tmp/test_mknod_fifo2"
      ],
      "args": ["-m", "644", "/tmp/test_mknod_fifo2", "p"],
      "expectation": {
        "execution": {
          "exit_code": 0,
          "stdout": "",
          "stderr": ""
        },
        "verifications": [
          {
            "command": "test -p /tmp/test_mknod_fifo2",
            "expected_exit": 0
          },
          {
            "command": "stat -c '%a' /tmp/test_mknod_fifo2 | grep -q '^644$'",
            "expected_exit": 0
          }
        ]
      },
      "cleanup_commands": [
        "rm -f /tmp/test_mknod_fifo2"
      ]
    },
    {
      "command": "mknod",
      "description": "Mode: create FIFO with -m 734 (from GNU test)",
      "setup_commands": [
        "rm -f /tmp/test_mknod_fifo3",
        "umask 777"
      ],
      "args": ["-m", "734", "/tmp/test_mknod_fifo3", "p"],
      "expectation": {
        "execution": {
          "exit_code": 0,
          "stdout": "",
          "stderr": ""
        },
        "verifications": [
          {
            "command": "test -p /tmp/test_mknod_fifo3",
            "expected_exit": 0
          },
          {
            "command": "stat -c '%a' /tmp/test_mknod_fifo3 | grep -q '^734$'",
            "expected_exit": 0
          }
        ]
      },
      "cleanup_commands": [
        "rm -f /tmp/test_mknod_fifo3",
        "umask 022"
      ]
    },
    {
      "command": "mknod",
      "description": "Mode: create FIFO with -m 755",
