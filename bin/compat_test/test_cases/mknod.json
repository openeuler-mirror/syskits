{
    "tests": [
        {
            "tstdin": "",
            "command": "mknod",
            "description": "基本功能测试 - 创建字符设备文件",
            "setup_commands": [],
            "args": ["char_dev", "c", "1", "1"],
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": "",
                    "stderr": ""
                },
                "verifications": [
                    {
                        "command": "test -c char_dev && echo 'Is char device'",
                        "expected_exit": 0,
                        "expected_stdout": "Is char device"
                    }
                ]
            },
            "cleanup_commands": [
                "rm -f char_dev"
            ]
        },
        {
            "tstdin": "",
            "command": "mknod",
            "description": "创建块设备文件",
            "setup_commands": [],
            "args": ["block_dev", "b", "1", "1"],
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": "",
                    "stderr": ""
                },
                "verifications": [
                    {
                        "command": "test -b block_dev && echo 'Is block device'",
                        "expected_exit": 0,
                        "expected_stdout": "Is block device"
                    }
                ]
            },
            "cleanup_commands": [
                "rm -f block_dev"
            ]
        },
        {
            "tstdin": "",
            "command": "mknod",
            "description": "创建FIFO文件",
            "setup_commands": [],
            "args": ["fifo_file", "p"],
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": "",
                    "stderr": ""
                },
                "verifications": [
                    {
                        "command": "test -p fifo_file && echo 'Is FIFO'",
                        "expected_exit": 0,
                        "expected_stdout": "Is FIFO"
                    }
                ]
            },
            "cleanup_commands": [
                "rm -f fifo_file"
            ]
        },
        {
            "tstdin": "",
            "command": "mknod",
            "description": "测试 -m 选项 - 设置权限模式",
            "setup_commands": [],
            "args": ["-m", "600", "char_dev_mode", "c", "1", "1"],
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": "",
                    "stderr": ""
                },
                "verifications": [
                    {
                        "command": "stat -c '%a' char_dev_mode",
                        "expected_exit": 0,
                        "expected_stdout": "600"
                    }
                ]
            },
            "cleanup_commands": [
                "rm -f char_dev_mode"
            ]
        },
        {
            "tstdin": "",
            "command": "mknod",
            "description": "测试十六进制设备号",
            "setup_commands": [],
            "args": ["hex_dev", "c", "0x1", "0x1"],
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": "",
                    "stderr": ""
                },
                "verifications": [
                    {
                        "command": "stat -c '%t %T' hex_dev",
                        "expected_exit": 0,
                        "expected_stdout": "1 1"
                    }
                ]
            },
            "cleanup_commands": [
                "rm -f hex_dev"
            ]
        },
        {
            "tstdin": "",
            "command": "mknod",
            "description": "测试八进制设备号",
            "setup_commands": [],
            "args": ["oct_dev", "c", "01", "01"],
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": "",
                    "stderr": ""
                },
                "verifications": [
                    {
                        "command": "stat -c '%t %T' oct_dev",
                        "expected_exit": 0,
                        "expected_stdout": "1 1"
                    }
                ]
            },
            "cleanup_commands": [
                "rm -f oct_dev"
            ]
        },
        {
            "tstdin": "",
            "command": "mknod",
            "description": "测试文件已存在",
            "setup_commands": [
                "touch existing_file"
            ],
            "args": ["existing_file", "c", "1", "1"],
            "expectation": {
                "execution": {
                    "exit_code": 1,
                    "stdout": "",
                    "stderr": "^mknod: failed to create 'existing_file': File exists\\n$"
                },
                "ignore_fields": {
                  "ignore_exit_code": true
                }
            },
            "cleanup_commands": [
                "rm -f existing_file"
            ]
        },
        {
            "tstdin": "",
            "command": "mknod",
            "description": "测试无效设备类型",
            "setup_commands": [],
            "args": ["invalid_dev", "x", "1", "1"],
            "expectation": {
                "execution": {
                    "exit_code": 1,
                    "stdout": "",
                    "stderr": "^mknod: invalid type: 'x'\\n$"
                }
            },
            "cleanup_commands": []
        },
        {
            "tstdin": "",
            "command": "mknod",
            "description": "测试缺少设备号",
            "setup_commands": [],
            "args": ["missing_dev", "c"],
            "expectation": {
                "execution": {
                    "exit_code": 1,
                    "stdout": "",
                    "stderr": "^mknod: missing operand after 'c'\\n$"
                }
            },
            "cleanup_commands": []
        },
        {
            "tstdin": "",
            "command": "mknod",
            "description": "测试 -Z 选项 - 设置 SELinux 安全上下文",
            "setup_commands": [],
            "args": ["-Z", "selinux_dev", "c", "1", "1"],
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": "",
                    "stderr": ""
                }
            },
            "cleanup_commands": [
                "rm -f selinux_dev"
            ]
        },
        {
            "tstdin": "",
            "command": "mknod",
            "description": "测试 --context 选项",
            "setup_commands": [],
            "args": ["--context=system_u:object_r:device_t:s0", "context_dev", "c", "1", "1"],
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": "",
                    "stderr": ""
                }
            },
            "cleanup_commands": [
                "rm -f context_dev"
            ]
        }
    ]
} 