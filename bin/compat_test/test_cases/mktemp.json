{
  "tests": [
    {
      "command": "mktemp",
      "description": "Basic file creation with template",
      "args": ["tmp.XXXXXX"],
      "setup_commands": ["cd /tmp"],
      "expectation": {
        "execution": {
          "exit_code": 0,
          "stdout": null,
          "stderr": ""
        },
        "verifications": [
          {
            "command": "test -f \"$CMD_STDOUT\" && test -r \"$CMD_STDOUT\" && test -w \"$CMD_STDOUT\"",
            "expected_exit": 0
          },
          {
            "command": "rm -f \"$CMD_STDOUT\"",
            "expected_exit": 0
          }
        ]
      },
      "cleanup_commands": ["cd -"]
    },
    {
      "command": "mktemp",
      "description": "Too many templates error",
      "args": ["-q", "a", "b"],
      "expectation": {
        "execution": {
          "exit_code": 1,
          "stdout": "",
          "stderr": null
        },
        "verifications": [
          {
            "command": "echo \"$CMD_STDERR\" | grep -q 'too many templates'",
            "expected_exit": 0
          }
        ]
      }
    },
    {
      "command": "mktemp",
      "description": "Too few X's in template",
      "args": ["-q", "foo.XX"],
      "expectation": {
        "execution": {
          "exit_code": 1,
          "stdout": "",
          "stderr": null
        },
        "verifications": [
          {
            "command": "echo \"$CMD_STDERR\" | grep -q \"too few X's in template\"",
            "expected_exit": 0
          }
        ]
      }
    },
