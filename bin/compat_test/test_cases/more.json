{
  "tests": [
    {
      "tstdin": "line1\nline2\n",
      "command": "more",
      "description": "stdin 非 TTY 直接输出",
      "args": [],
      "expectation": {
        "execution": {
          "exit_code": 0,
          "stdout": "line1\nline2\n",
          "stderr": ""
        }
      }
    },
    {
      "tstdin": "",
      "command": "more",
      "description": "单文件输出包含文件头",
      "setup_commands": [
        "printf 'line1\\nline2\\nline3\\n' > test_file1"
      ],
      "args": ["test_file1"],
      "expectation": {
        "execution": {
          "exit_code": 0,
          "stdout": "::::::::::::::\ntest_file1\n::::::::::::::\nline1\nline2\nline3\n",
          "stderr": ""
        }
      },
      "cleanup_commands": [
        "rm -f test_file1"
      ]
    },
    {
      "tstdin": "",
      "command": "more",
      "description": "多文件输出保留原始换行边界",
      "setup_commands": [
        "printf 'A' > file1",
        "printf 'B\\n' > file2"
      ],
      "args": ["file1", "file2"],
      "expectation": {
        "execution": {
          "exit_code": 0,
          "stdout": "::::::::::::::\nfile1\n::::::::::::::\nA::::::::::::::\nfile2\n::::::::::::::\nB\n",
          "stderr": ""
        }
      },
      "cleanup_commands": [
        "rm -f file1 file2"
      ]
    },
    {
      "tstdin": "",
      "command": "more",
      "description": "目录参数输出提示到 stdout",
      "setup_commands": [
        "mkdir -p test_dir",
        "printf 'x\\n' > file1"
      ],
      "args": ["test_dir", "file1"],
      "expectation": {
        "execution": {
          "exit_code": 0,
          "stdout": "\n*** test_dir: directory ***\n\n::::::::::::::\nfile1\n::::::::::::::\nx\n",
          "stderr": ""
        }
      },
      "cleanup_commands": [
        "rm -rf test_dir file1"
      ]
    },
    {
      "tstdin": "",
      "command": "more",
      "description": "缺失文件错误输出到 stderr",
      "setup_commands": [
        "rm -f missing_file"
      ],
      "args": ["missing_file"],
      "expectation": {
        "execution": {
          "exit_code": 0,
          "stdout": "",
          "stderr": "more: cannot open missing_file: No such file or directory\n"
        }
      }
    },
    {
      "tstdin": "",
      "command": "more",
      "description": "-d 在非 TTY 下无影响",
      "setup_commands": [
        "printf 'line1\\n' > test_file"
      ],
      "args": ["-d", "test_file"],
      "expectation": {
        "execution": {
          "exit_code": 0,
          "stdout": "::::::::::::::\ntest_file\n::::::::::::::\nline1\n",
          "stderr": ""
        }
      },
      "cleanup_commands": [
        "rm -f test_file"
      ]
    },
    {
      "tstdin": "",
      "command": "more",
      "description": "-f 在非 TTY 下无影响",
      "setup_commands": [
