    {
      "tstdin": "",
      "command": "more",
      "description": "+<number> 在非 TTY 下无影响",
      "setup_commands": [
        "printf 'line1\\nline2\\nline3\\n' > test_file"
      ],
      "args": ["+3", "test_file"],
      "expectation": {
        "execution": {
          "exit_code": 0,
          "stdout": "::::::::::::::\ntest_file\n::::::::::::::\nline1\nline2\nline3\n",
          "stderr": ""
        }
      },
      "cleanup_commands": [
        "rm -f test_file"
      ]
    },
    {
      "tstdin": "",
      "command": "more",
      "description": "+/pattern 在非 TTY 下无影响",
      "setup_commands": [
        "printf 'line1\\nline2\\nline3\\n' > test_file"
      ],
      "args": ["+/line3", "test_file"],
      "expectation": {
        "execution": {
          "exit_code": 0,
          "stdout": "::::::::::::::\ntest_file\n::::::::::::::\nline1\nline2\nline3\n",
          "stderr": ""
        }
      },
      "cleanup_commands": [
        "rm -f test_file"
      ]
    },
    {
      "tstdin": "abba\nbar\nfoo\nxyzzy\n",
      "command": "more",
      "description": "util-linux regexp（非 TTY 适配）",
      "args": ["+/foo"],
      "expectation": {
        "execution": {
          "exit_code": 0,
          "stdout": "abba\nbar\nfoo\nxyzzy\n",
          "stderr": ""
        }
      }
    },
    {
      "tstdin": "a\n\n\nb\n",
      "command": "more",
      "description": "util-linux squeeze（非 TTY 适配）",
      "args": ["-s"],
      "expectation": {
        "execution": {
          "exit_code": 0,
          "stdout": "a\n\n\nb\n",
          "stderr": ""
        }
      }
    },
    {
      "tstdin": "line1\nline2\n",
      "command": "more",
      "description": "TTY stdin + -e（EOF 退出）",
      "setup_commands": ["export TERM=linux"],
      "args": ["-e"],
      "tty": true,
      "timeout": 5,
      "expectation": {
        "execution": {
          "exit_code": 0
        }
      }
    },
    {
      "tstdin": "line1\nline2\n",
      "command": "more",
      "description": "TTY stdin + -d（静默提示）",
      "setup_commands": ["export TERM=linux"],
      "args": ["-d"],
      "tty": true,
      "timeout": 5,
      "expectation": {
        "execution": {
          "exit_code": 0
        }
      }
    },
    {
      "tstdin": "abba\nbar\nfoo\nxyzzy\n",
      "command": "more",
      "description": "util-linux regexp（TTY）",
      "setup_commands": ["export TERM=linux"],
      "args": ["+/foo"],
      "tty": true,
      "timeout": 5,
      "expectation": {
        "execution": {
          "exit_code": 0,
          "stdout": "\n...skipping\nfoo\nxyzzy\n",
          "stderr": ""
        }
      }
    },
    {
      "tstdin": "a\n\n\nb\n",
      "command": "more",
      "description": "util-linux squeeze（TTY）",
      "setup_commands": ["export TERM=linux"],
      "args": ["-s"],
      "tty": true,
      "timeout": 5,
      "expectation": {
        "execution": {
          "exit_code": 0,
          "stdout": "a\n\nb\n",
          "stderr": ""
        }
      }
    }
