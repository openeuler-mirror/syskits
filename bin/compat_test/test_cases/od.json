{
    "tests": [
        {
            "command": "od",
            "description": "Default output (octal 2-byte units)",
            "args": [
                "input"
            ],
            "setup_commands": [
                "printf '0123456789abcdef' > input"
            ],
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": null,
                    "stderr": ""
                },
                "verifications": [
                    {
                        "command": "od input > expected && diff expected $CMD_STDOUT",
                        "expected_exit": 0
                    }
                ]
            },
            "cleanup_commands": [
                "rm -f input expected"
            ]
        },
