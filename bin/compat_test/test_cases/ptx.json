{
  "tests": [
    {
      "command": "ptx",
      "description": "Basic ptx with single token",
      "args": [
        "-w10"
      ],
      "setup_commands": [
        "echo 'bar' > /tmp/test_ptx_1tok.txt"
      ],
      "input_files": [
        "/tmp/test_ptx_1tok.txt"
      ],
      "expectation": {
        "execution": {
          "exit_code": 0,
          "stdout": "        bar\n",
          "stderr": ""
        }
      },
      "cleanup_commands": [
        "rm -f /tmp/test_ptx_1tok.txt"
      ]
    },
    {
      "command": "ptx",
      "description": "Basic ptx with two tokens",
      "args": [
        "-w10"
      ],
      "setup_commands": [
        "echo 'foo bar' > /tmp/test_ptx_2tok.txt"
      ],
      "input_files": [
        "/tmp/test_ptx_2tok.txt"
      ],
      "expectation": {
        "execution": {
          "exit_code": 0,
          "stdout": "     /   bar\n        foo/\n",
          "stderr": ""
        }
      },
      "cleanup_commands": [
        "rm -f /tmp/test_ptx_2tok.txt"
      ]
    },
    {
      "command": "ptx",
      "description": "Narrow width test (w2) - should not infloop",
      "args": [
        "-w2"
      ],
      "setup_commands": [
        "echo 'qux' > /tmp/test_ptx_narrow.txt"
      ],
      "input_files": [
        "/tmp/test_ptx_narrow.txt"
      ],
      "expectation": {
        "execution": {
          "exit_code": 0,
          "stdout": "      qux\n",
          "stderr": ""
        }
      },
      "cleanup_commands": [
        "rm -f /tmp/test_ptx_narrow.txt"
      ]
    },
    {
      "command": "ptx",
      "description": "Narrow width with gap size (g1 w2)",
      "args": [
        "-g1",
        "-w2"
      ],
      "setup_commands": [
        "echo 'ta' > /tmp/test_ptx_narrow_g.txt"
      ],
      "input_files": [
        "/tmp/test_ptx_narrow_g.txt"
      ],
      "expectation": {
        "execution": {
          "exit_code": 0,
          "stdout": "  ta\n",
          "stderr": ""
        }
      },
      "cleanup_commands": [
        "rm -f /tmp/test_ptx_narrow_g.txt"
      ]
    },
    {
      "command": "ptx",
      "description": "Two separate input files",
      "args": [
        "-g1",
        "-w1"
      ],
      "setup_commands": [
        "echo 'a' > /tmp/test_ptx_f1.txt",
        "echo 'b' > /tmp/test_ptx_f2.txt"
      ],
      "input_files": [
        "/tmp/test_ptx_f1.txt",
        "/tmp/test_ptx_f2.txt"
      ],
      "expectation": {
        "execution": {
          "exit_code": 0,
          "stdout": "  a\n  b\n",
          "stderr": ""
        }
      },
      "cleanup_commands": [
        "rm -f /tmp/test_ptx_f1.txt /tmp/test_ptx_f2.txt"
      ]
    },
    {
      "command": "ptx",
      "description": "Format roff output",
      "args": [
        "--format=roff"
      ],
      "setup_commands": [
        "echo 'foo' > /tmp/test_ptx_roff.txt"
      ],
      "input_files": [
        "/tmp/test_ptx_roff.txt"
      ],
      "expectation": {
        "execution": {
          "exit_code": 0,
          "stdout": ".xx \"\" \"\" \"foo\" \"\"\n",
          "stderr": ""
        }
      },
      "cleanup_commands": [
        "rm -f /tmp/test_ptx_roff.txt"
      ]
    },
    {
      "command": "ptx",
      "description": "Format tex output",
      "args": [
        "--format=tex"
      ],
      "setup_commands": [
        "echo 'foo' > /tmp/test_ptx_tex.txt"
      ],
      "input_files": [
        "/tmp/test_ptx_tex.txt"
      ],
      "expectation": {
        "execution": {
          "exit_code": 0,
          "stdout": "\\xx {}{}{foo}{}{}\n",
          "stderr": ""
        }
      },
      "cleanup_commands": [
        "rm -f /tmp/test_ptx_tex.txt"
      ]
    },
    {
      "command": "ptx",
      "description": "Test -O flag (format=roff short form)",
      "args": [
        "-O"
      ],
      "setup_commands": [
        "echo 'test' > /tmp/test_ptx_O.txt"
      ],
      "input_files": [
        "/tmp/test_ptx_O.txt"
      ],
      "expectation": {
        "execution": {
          "exit_code": 0,
          "stdout": ".xx \"\" \"\" \"test\" \"\"\n",
          "stderr": ""
        }
      },
      "cleanup_commands": [
        "rm -f /tmp/test_ptx_O.txt"
      ]
    },
    {
      "command": "ptx",
      "description": "Test -T flag (format=tex short form)",
      "args": [
        "-T"
      ],
      "setup_commands": [
        "echo 'test' > /tmp/test_ptx_T.txt"
      ],
      "input_files": [
        "/tmp/test_ptx_T.txt"
      ],
      "expectation": {
        "execution": {
          "exit_code": 0,
          "stdout": "\\xx {}{}{test}{}{}\n",
          "stderr": ""
        }
      },
      "cleanup_commands": [
        "rm -f /tmp/test_ptx_T.txt"
      ]
    },
    {
      "command": "ptx",
      "description": "Test stdin input (no file argument)",
      "args": [
        "-w20"
      ],
      "setup_commands": [
        "echo 'stdin test' > /tmp/test_ptx_stdin_input.txt"
      ],
      "stdin_file": "/tmp/test_ptx_stdin_input.txt",
      "expectation": {
        "execution": {
          "exit_code": 0,
          "stdout": null,
          "stderr": ""
        },
        "verifications": [
          {
            "command": "echo \"$CMD_STDOUT\" | grep -q 'stdin'",
            "expected_exit": 0
          },
          {
            "command": "echo \"$CMD_STDOUT\" | grep -q 'test'",
            "expected_exit": 0
          }
        ]
      },
      "cleanup_commands": [
        "rm -f /tmp/test_ptx_stdin_input.txt"
      ]
    },
    {
      "command": "ptx",
      "description": "Test dash (-) as stdin",
      "args": [
        "-w20",
        "-"
      ],
      "setup_commands": [
        "echo 'dash test' > /tmp/test_ptx_dash_input.txt"
      ],
      "stdin_file": "/tmp/test_ptx_dash_input.txt",
      "expectation": {
        "execution": {
          "exit_code": 0,
          "stdout": null,
          "stderr": ""
        },
        "verifications": [
          {
            "command": "echo \"$CMD_STDOUT\" | grep -q 'dash'",
            "expected_exit": 0
          }
        ]
      },
      "cleanup_commands": [
        "rm -f /tmp/test_ptx_dash_input.txt"
      ]
    },
    {
      "command": "ptx",
      "description": "Test --help flag",
      "args": [
        "--help"
      ],
      "expectation": {
        "execution": {
          "exit_code": 0,
          "stdout": null,
          "stderr": ""
        },
        "verifications": [
          {
            "command": "echo \"$CMD_STDOUT\" | grep -q 'Usage:'",
            "expected_exit": 0
          },
          {
            "command": "echo \"$CMD_STDOUT\" | grep -q 'permuted index'",
            "expected_exit": 0
          }
        ]
      }
    },
    {
      "command": "ptx",
      "description": "Test --version flag",
      "args": [
        "--version"
      ],
      "expectation": {
        "execution": {
          "exit_code": 0,
          "stdout": null,
          "stderr": ""
        },
        "verifications": [
          {
            "command": "echo \"$CMD_STDOUT\" | grep -iq 'ptx'",
            "expected_exit": 0
          }
        ]
      }
    }
  ]
}
