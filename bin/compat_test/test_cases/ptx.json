{
  "tests": [
    {
      "command": "ptx",
      "description": "Basic ptx with single token",
      "args": [
        "-w10"
      ],
      "setup_commands": [
        "echo 'bar' > /tmp/test_ptx_1tok.txt"
      ],
      "input_files": [
        "/tmp/test_ptx_1tok.txt"
      ],
      "expectation": {
        "execution": {
          "exit_code": 0,
          "stdout": "        bar\n",
          "stderr": ""
        }
      },
      "cleanup_commands": [
        "rm -f /tmp/test_ptx_1tok.txt"
      ]
    },
