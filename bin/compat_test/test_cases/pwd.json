{
  "tests": [
    {
      "command": "pwd",
      "description": "Basic pwd with no options - should output current directory",
      "args": [],
      "expectation": {
        "execution": {
          "exit_code": 0,
          "stdout": null,
          "stderr": ""
        },
        "verifications": [
          {
            "command": "test -n \"$CMD_STDOUT\"",
            "expected_exit": 0,
            "expected_stdout": null,
            "expected_stderr": null
          },
          {
            "command": "test -d \"$CMD_STDOUT\"",
            "expected_exit": 1,
            "expected_stdout": null,
            "expected_stderr": null
          }
        ]
      }
    },
    {
      "command": "pwd",
      "description": "Test -P flag (physical path) - should resolve symlinks",
      "args": ["-P"],
      "setup_commands": [
        "mkdir -p /tmp/test_pwd_real_$$",
        "ln -s /tmp/test_pwd_real_$$ /tmp/test_pwd_link_$$",
        "cd /tmp/test_pwd_link_$$"
      ],
      "expectation": {
        "execution": {
          "exit_code": 0,
          "stdout": null,
          "stderr": ""
        },
        "verifications": [
          {
            "command": "echo \"$CMD_STDOUT\" | grep -q '/test_pwd_real_'",
            "expected_exit": 0,
            "expected_stdout": null,
            "expected_stderr": null
          }
        ]
      },
      "cleanup_commands": [
        "cd /",
        "rm -rf /tmp/test_pwd_link_$$ /tmp/test_pwd_real_$$"
      ]
    },
    {
      "command": "pwd",
      "description": "Test --physical flag (long form) - should resolve symlinks",
      "args": ["--physical"],
      "setup_commands": [
        "mkdir -p /tmp/test_pwd_phys_$$",
        "ln -s /tmp/test_pwd_phys_$$ /tmp/test_pwd_sym_$$",
        "cd /tmp/test_pwd_sym_$$"
      ],
      "expectation": {
        "execution": {
          "exit_code": 0,
          "stdout": null,
          "stderr": ""
        },
        "verifications": [
          {
            "command": "echo \"$CMD_STDOUT\" | grep -q '/test_pwd_phys_'",
            "expected_exit": 0,
            "expected_stdout": null,
            "expected_stderr": null
          }
        ]
      },
      "cleanup_commands": [
        "cd /",
        "rm -rf /tmp/test_pwd_sym_$$ /tmp/test_pwd_phys_$$"
      ]
    },
    {
      "command": "pwd",
      "description": "Test -L flag (logical path) - should preserve symlinks",
      "args": ["-L"],
      "setup_commands": [
        "mkdir -p /tmp/test_pwd_logical_$$",
        "ln -s /tmp/test_pwd_logical_$$ /tmp/test_pwd_lsym_$$",
        "cd /tmp/test_pwd_lsym_$$",
        "export PWD=/tmp/test_pwd_lsym_$$"
      ],
      "expectation": {
        "execution": {
          "exit_code": 0,
          "stdout": null,
          "stderr": ""
        },
        "verifications": [
          {
            "command": "echo \"$CMD_STDOUT\" | grep -q '/test_pwd_lsym_'",
            "expected_exit": 0,
            "expected_stdout": null,
            "expected_stderr": null
          }
        ]
      },
      "cleanup_commands": [
        "cd /",
        "unset PWD",
        "rm -rf /tmp/test_pwd_lsym_$$ /tmp/test_pwd_logical_$$"
      ]
    },
    {
      "command": "pwd",
      "description": "Test --logical flag (long form) - should preserve symlinks",
      "args": ["--logical"],
      "setup_commands": [
        "mkdir -p /tmp/test_pwd_log_$$",
