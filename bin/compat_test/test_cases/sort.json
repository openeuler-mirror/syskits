{
    "tests": [
        {
            "tstdin": "",
            "command": "sort",
            "description": "基本功能测试 - 默认排序",
            "setup_commands": [
                "echo -e 'c\\nb\\na' > test.txt"
            ],
            "args": ["test.txt"],
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": "a\nb\nc\n",
                    "stderr": ""
                }
            },
            "cleanup_commands": [
                "rm -f test.txt"
            ]
        },
        {
            "tstdin": "",
            "command": "sort",
            "description": "测试 -r 选项 - 逆序排序",
            "setup_commands": [
                "echo -e 'a\\nb\\nc' > test.txt"
            ],
            "args": ["-r", "test.txt"],
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": "c\nb\na\n",
                    "stderr": ""
                }
            },
            "cleanup_commands": [
                "rm -f test.txt"
            ]
        },
        {
            "tstdin": "",
            "command": "sort",
            "description": "测试 -n 选项 - 数值排序",
            "setup_commands": [
                "echo -e '10\\n2\\n1' > test.txt"
            ],
            "args": ["-n", "test.txt"],
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": "1\n2\n10\n",
                    "stderr": ""
                }
            },
            "cleanup_commands": [
                "rm -f test.txt"
            ]
        },
        {
            "tstdin": "",
            "command": "sort",
            "description": "测试 -M 选项在 C locale 下 - 英文月份排序",
            "setup_commands": [
                "echo -e 'Dec\\nJan\\nFeb\\nMar' > test.txt"
            ],
            "args": ["-M", "test.txt"],
            "env": {
                "LC_TIME": "C"
            },
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": "Jan\nFeb\nMar\nDec\n",
                    "stderr": ""
                }
            },
            "cleanup_commands": [
                "rm -f test.txt"
            ]
        },
        {
            "tstdin": "",
            "command": "sort",
            "description": "测试 -M 选项在中文 locale 下 - 支持中文月份",
            "setup_commands": [
                "echo -e '十二月\\n一月\\n二月\\n三月' > test.txt"
            ],
            "args": ["-M", "test.txt"],
            "env": {
                "LC_TIME": "zh_CN.UTF-8"
            },
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": "一月\n二月\n三月\n十二月\n",
                    "stderr": ""
                }
            },
            "cleanup_commands": [
                "rm -f test.txt"
            ]
        },
        {
            "tstdin": "",
            "command": "sort",
            "description": "测试 -M 选项混合英文和中文月份",
            "setup_commands": [
                "echo -e 'Dec\\n一月\\nFeb\\n三月' > test.txt"
            ],
            "args": ["-M", "test.txt"],
            "env": {
                "LC_TIME": "zh_CN.UTF-8"
            },
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": "一月\nFeb\n三月\nDec\n",
                    "stderr": ""
                }
            },
            "cleanup_commands": [
                "rm -f test.txt"
            ]
        },
        {
            "tstdin": "",
            "command": "sort",
            "description": "测试 -u 选项 - 去重排序",
            "setup_commands": [
                "echo -e 'a\\nb\\na\\nc' > test.txt"
            ],
            "args": ["-u", "test.txt"],
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": "a\nb\nc\n",
                    "stderr": ""
                }
            },
            "cleanup_commands": [
                "rm -f test.txt"
            ]
        },
        {
            "tstdin": "",
            "command": "sort",
            "description": "测试 -k 选项 - 按指定列排序",
            "setup_commands": [
                "echo -e '1 c\\n2 a\\n3 b' > test.txt"
            ],
            "args": ["-k", "2", "test.txt"],
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": "2 a\n3 b\n1 c\n",
                    "stderr": ""
                }
            },
            "cleanup_commands": [
                "rm -f test.txt"
            ]
        },
        {
            "tstdin": "",
            "command": "sort",
            "description": "测试 -t 选项 - 自定义字段分隔符",
            "setup_commands": [
                "echo -e '1:c\\n2:a\\n3:b' > test.txt"
            ],
            "args": ["-t", ":", "-k", "2", "test.txt"],
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": "2:a\n3:b\n1:c\n",
                    "stderr": ""
                }
            },
            "cleanup_commands": [
                "rm -f test.txt"
            ]
        },
        {
            "tstdin": "",
            "command": "sort",
            "description": "测试标准输入",
            "input": "c\nb\na\n",
            "args": [],
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": "a\nb\nc\n",
                    "stderr": ""
                }
            }
        },
        {
            "tstdin": "",
            "command": "sort", 
            "description": "测试 C locale 下的字符串排序（字节比较）",
            "setup_commands": [
                "echo -e 'Windows\\nlinux\\nwindows\\nApple' > test.txt"
            ],
            "args": ["test.txt"],
            "env": {
                "LC_COLLATE": "C"
            },
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": "Apple\nWindows\nlinux\nwindows\n",
                    "stderr": ""
                }
            },
            "cleanup_commands": [
                "rm -f test.txt"
            ]
        },
        {
            "tstdin": "",
            "command": "sort",
            "description": "测试 UTF-8 locale 下的字符串排序（字典序比较）",
            "setup_commands": [
                "echo -e 'Windows\\nlinux\\nwindows\\nApple' > test.txt"
            ],
            "args": ["test.txt"],
            "env": {
                "LC_COLLATE": "en_US.UTF-8"
            },
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": "Apple\nlinux\nWindows\nwindows\n",
                    "stderr": ""
                }
            },
            "cleanup_commands": [
                "rm -f test.txt"
            ]
        },
        {
            "tstdin": "",
            "command": "sort",
            "description": "测试混合大小写在不同 locale 下的排序差异",
            "setup_commands": [
                "echo -e 'banana\\nApple\\ncherry\\nDragon' > test.txt"
            ],
            "args": ["test.txt"],
            "env": {
                "LC_COLLATE": "en_US.UTF-8"
            },
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": "Apple\nbanana\ncherry\nDragon\n",
                    "stderr": ""
                }
            },
            "cleanup_commands": [
                "rm -f test.txt"
            ]
        },
        {
            "tstdin": "",
            "command": "sort",
            "description": "测试带有特殊字符的 Unicode 排序",
            "setup_commands": [
                "echo -e 'café\\nnaïve\\napple\\nzèbre' > test.txt"
            ],
            "args": ["test.txt"],
            "env": {
                "LC_COLLATE": "en_US.UTF-8"
            },
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": "apple\ncafé\nnaïve\nzèbre\n",
                    "stderr": ""
                }
            },
            "cleanup_commands": [
                "rm -f test.txt"
            ]
        },
        {
            "tstdin": "",
            "command": "sort",
            "description": "测试中文字符在 UTF-8 locale 下的排序",
            "setup_commands": [
                "echo -e '北京\\n上海\\n广州\\n深圳' > test.txt"
            ],
            "args": ["test.txt"],
            "env": {
                "LC_COLLATE": "zh_CN.UTF-8"
            },
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": "北京\n广州\n上海\n深圳\n",
                    "stderr": ""
                }
            },
            "cleanup_commands": [
                "rm -f test.txt"
            ]
        },
        {
            "tstdin": "",
            "command": "sort",
            "description": "测试 POSIX locale 下的排序行为",
            "setup_commands": [
                "echo -e 'Test1\\ntest2\\nTEST3\\ntest4' > test.txt"
            ],
            "args": ["test.txt"],
            "env": {
                "LC_COLLATE": "POSIX"
            },
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": "TEST3\nTest1\ntest2\ntest4\n",
                    "stderr": ""
                }
            },
            "cleanup_commands": [
                "rm -f test.txt"
            ]
        },
        {
            "tstdin": "",
            "command": "sort",
            "description": "测试 -f 选项与 locale 的结合（忽略大小写排序）",
            "setup_commands": [
                "echo -e 'Apple\\nbanana\\nCherry\\ndragon' > test.txt"
            ],
            "args": ["-f", "test.txt"],
            "env": {
                "LC_COLLATE": "en_US.UTF-8"
            },
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": "Apple\nbanana\nCherry\ndragon\n",
                    "stderr": ""
                }
            },
            "cleanup_commands": [
                "rm -f test.txt"
            ]
        }
    ]
}