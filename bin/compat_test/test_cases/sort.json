{
    "tests": [
        {
            "tstdin": "",
            "command": "sort",
            "description": "基本功能测试 - 默认排序",
            "setup_commands": [
                "echo -e 'c\\nb\\na' > test.txt"
            ],
            "args": ["test.txt"],
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": "a\nb\nc\n",
                    "stderr": ""
                }
            },
            "cleanup_commands": [
                "rm -f test.txt"
            ]
        },
        {
            "tstdin": "",
            "command": "sort",
            "description": "测试 -r 选项 - 逆序排序",
            "setup_commands": [
                "echo -e 'a\\nb\\nc' > test.txt"
            ],
            "args": ["-r", "test.txt"],
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": "c\nb\na\n",
                    "stderr": ""
                }
            },
            "cleanup_commands": [
                "rm -f test.txt"
            ]
        },
        {
            "tstdin": "",
            "command": "sort",
            "description": "测试 -n 选项 - 数值排序",
            "setup_commands": [
                "echo -e '10\\n2\\n1' > test.txt"
            ],
            "args": ["-n", "test.txt"],
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": "1\n2\n10\n",
                    "stderr": ""
                }
            },
            "cleanup_commands": [
                "rm -f test.txt"
            ]
        },
        {
            "tstdin": "",
            "command": "sort",
            "description": "测试 -M 选项在 C locale 下 - 英文月份排序",
            "setup_commands": [
                "echo -e 'Dec\\nJan\\nFeb\\nMar' > test.txt"
            ],
            "args": ["-M", "test.txt"],
            "env": {
                "LC_TIME": "C"
            },
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": "Jan\nFeb\nMar\nDec\n",
                    "stderr": ""
                }
            },
            "cleanup_commands": [
                "rm -f test.txt"
            ]
        },
        {
            "tstdin": "",
            "command": "sort",
            "description": "测试 -M 选项在中文 locale 下 - 支持中文月份",
            "setup_commands": [
                "echo -e '十二月\\n一月\\n二月\\n三月' > test.txt"
            ],
            "args": ["-M", "test.txt"],
            "env": {
                "LC_TIME": "zh_CN.UTF-8"
            },
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": "一月\n二月\n三月\n十二月\n",
                    "stderr": ""
                }
            },
            "cleanup_commands": [
                "rm -f test.txt"
            ]
        },
        {
            "tstdin": "",
            "command": "sort",
            "description": "测试 -M 选项混合英文和中文月份",
            "setup_commands": [
                "echo -e 'Dec\\n一月\\nFeb\\n三月' > test.txt"
            ],
            "args": ["-M", "test.txt"],
            "env": {
                "LC_TIME": "zh_CN.UTF-8"
            },
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": "一月\nFeb\n三月\nDec\n",
                    "stderr": ""
                }
            },
            "cleanup_commands": [
                "rm -f test.txt"
            ]
        },
        {
            "tstdin": "",
            "command": "sort",
            "description": "测试 -u 选项 - 去重排序",
            "setup_commands": [
                "echo -e 'a\\nb\\na\\nc' > test.txt"
            ],
            "args": ["-u", "test.txt"],
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": "a\nb\nc\n",
                    "stderr": ""
                }
            },
            "cleanup_commands": [
                "rm -f test.txt"
            ]
        },
        {
            "tstdin": "",
            "command": "sort",
            "description": "测试 -k 选项 - 按指定列排序",
            "setup_commands": [
                "echo -e '1 c\\n2 a\\n3 b' > test.txt"
            ],
            "args": ["-k", "2", "test.txt"],
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": "2 a\n3 b\n1 c\n",
                    "stderr": ""
                }
            },
            "cleanup_commands": [
                "rm -f test.txt"
            ]
        },
        {
            "tstdin": "",
            "command": "sort",
            "description": "测试 -t 选项 - 自定义字段分隔符",
            "setup_commands": [
                "echo -e '1:c\\n2:a\\n3:b' > test.txt"
            ],
            "args": ["-t", ":", "-k", "2", "test.txt"],
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": "2:a\n3:b\n1:c\n",
                    "stderr": ""
                }
            },
            "cleanup_commands": [
                "rm -f test.txt"
            ]
        },
        {
            "tstdin": "",
            "command": "sort",
            "description": "测试标准输入",
            "input": "c\nb\na\n",
            "args": [],
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": "a\nb\nc\n",
                    "stderr": ""
                }
            }
        }
    ]
}