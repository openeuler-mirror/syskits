{
  "tests": [
    {
      "command": "split",
      "description": "split lines: --lines=2 basic output files",
      "args": [
        "--lines=2",
        "in"
      ],
      "setup_commands": [
        "printf '1\\n2\\n3\\n4\\n5\\n' > in",
        "printf '1\\n2\\n' > exp1",
        "printf '3\\n4\\n' > exp2",
        "printf '5\\n' > exp3"
      ],
      "expectation": {
        "execution": {
          "exit_code": 0,
          "stdout": "",
          "stderr": ""
        },
        "verifications": [
          {
            "command": "cmp -s exp1 xaa",
            "expected_exit": 0,
            "expected_stdout": null,
            "expected_stderr": null
          },
          {
            "command": "cmp -s exp2 xab",
            "expected_exit": 0,
            "expected_stdout": null,
            "expected_stderr": null
          },
          {
            "command": "cmp -s exp3 xac",
            "expected_exit": 0,
            "expected_stdout": null,
            "expected_stderr": null
          },
          {
            "command": "test ! -e xad",
            "expected_exit": 0,
            "expected_stdout": null,
            "expected_stderr": null
          }
        ],
        "ignore_fields": {
          "ignore_exit_code": false,
          "ignore_stdout": false,
          "ignore_stderr": false,
          "ignore_verifications": false
        }
      },
      "cleanup_commands": [
        "rm -f in exp1 exp2 exp3 x*"
      ]
    },
