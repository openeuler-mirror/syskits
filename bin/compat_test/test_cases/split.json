    {
      "command": "split",
      "description": "split numeric suffix auto widening when no start specified",
      "args": [
        "-b",
        "1",
        "--numeric-suffixes",
        "file.in",
        "x"
      ],
      "setup_commands": [
        "truncate -s91 file.in"
      ],
      "expectation": {
        "execution": {
          "exit_code": 0,
          "stdout": "",
          "stderr": ""
        },
        "verifications": [
          {
            "command": "test -e x89 && test -e x9000",
            "expected_exit": 0,
            "expected_stdout": null,
            "expected_stderr": null
          },
          {
            "command": "test $(ls x*[0-9]* | wc -l) -eq 91",
            "expected_exit": 0,
            "expected_stdout": null,
            "expected_stderr": null
          }
        ],
        "ignore_fields": {
          "ignore_exit_code": false,
          "ignore_stdout": false,
          "ignore_stderr": false,
          "ignore_verifications": false
        }
      },
      "cleanup_commands": [
        "rm -f file.in x*"
      ]
