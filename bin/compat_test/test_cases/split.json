{
    "tests": [
        {
            "command": "split",
            "description": "split: 按行拆分文件，每10行一个输出文件",
            "args": [
                "-l", "10",
                "test_file_split.txt",
                "out_"
            ],
            "setup_commands": [
                "seq 1 98 > test_file_split.txt"
            ],
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": "",
                    "stderr": ""
                },
                "verifications": [
                    {
                        "command": "ls out_* | wc -l",
                        "expected_exit": 0,
                        "expected_stdout": "",
                        "expected_stderr": null
                    },
                    {
                        "command": "cat out_*",
                        "expected_exit": 0,
                        "expected_stdout": "",
                        "expected_stderr": null
                    }
                ],
                "ignore_fields": {
                    "ignore_exit_code": false,
                    "ignore_stdout": false,
                    "ignore_stderr": false,
                    "ignore_function": false
                }
            },
            "cleanup_commands": [
                "rm -f test_file_split.txt out_*"
            ]
        },
        {
            "command": "split",
            "description": "split: 按行拆分文件，文件行数小于参数，应该输出一个文件",
            "args": [
                "-l", "100",
                "test_file_split.txt",
                "out_"
            ],
            "setup_commands": [
                "seq 1 10 > test_file_split.txt"
            ],
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": "",
                    "stderr": ""
                },
                "verifications": [
                    {
                        "command": "cat out_*",
                        "expected_exit": 0,
                        "expected_stdout": "",
                        "expected_stderr": null
                    },
                    {
                        "command": "ls out_* | wc -l",
                        "expected_exit": 0,
                        "expected_stdout": "",
                        "expected_stderr": null
                    }
                ],
                "ignore_fields": {
                    "ignore_exit_code": false,
                    "ignore_stdout": false,
                    "ignore_stderr": false,
                    "ignore_function": false
                }
            },
            "cleanup_commands": [
                "rm -f test_file_split.txt out_*"
            ]
        },
        {
