                    "ignore_stderr": false,
                    "ignore_function": false
                }
            },
            "cleanup_commands": [
                "rm -f test_file_split.txt out_*"
            ]
        },
        {
            "command": "split",
            "description": "split: 使用数字后缀 (-d) 并指定后缀长度 (-a 3)",
            "args": [
                "-l", "10",
                "-d",
                "-a", "3",
                "test_file_split.txt",
                "out_"
            ],
            "setup_commands": [
                "seq 1 35 > test_file_split.txt"
            ],
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": "",
                    "stderr": ""
                },
                "verifications": [
                    {
                        "command": "ls out_* | wc -l",
                        "expected_exit": 0,
                        "expected_stdout": "",
                        "expected_stderr": null
                    },
                    {
                        "command": "ls out_[0-9][0-9][0-9] | wc -l",
                        "expected_exit": 0,
                        "expected_stdout": "",
                        "expected_stderr": null
                    },
                    {
                        "command": "cat out_*",
                        "expected_exit": 0,
                        "expected_stdout": "",
                        "expected_stderr": null
                    }
                ],
                "ignore_fields": {
                    "ignore_exit_code": false,
                    "ignore_stdout": false,
                    "ignore_stderr": false,
                    "ignore_function": false
                }
            },
            "cleanup_commands": [
                "rm -f test_file_split.txt out_*"
            ]
        },
