{
    "tests": [
        {
            "tstdin": "",
            "command": "stat",
            "description": "基本功能测试",
            "setup_commands": [],
            "args": ["/etc/passwd"],
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": ".*File:.*/etc/passwd.*Size:.*Blocks:.*IO Block:.*regular file.*Device:.*Inode:.*Links:.*Access:.*Uid:.*Gid:.*Access:.*Modify:.*Change:.*Birth:.*",
                    "stderr": ""
                }
            },
            "cleanup_commands": []
        },
        {
            "tstdin": "",
            "command": "stat",
            "description": "时间戳格式一致性测试",
            "setup_commands": [],
            "args": ["-c", "%x|%y|%z|%w", "/etc/passwd"],
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": "^[0-9]{4}-[0-9]{2}-[0-9]{2} [0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]+ \\+[0-9]{4}\\|[0-9]{4}-[0-9]{2}-[0-9]{2} [0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]+ \\+[0-9]{4}\\|[0-9]{4}-[0-9]{2}-[0-9]{2} [0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]+ \\+[0-9]{4}\\|[0-9]{4}-[0-9]{2}-[0-9]{2} [0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]+ \\+[0-9]{4}$",
                    "stderr": ""
                }
            },
            "cleanup_commands": []
        },
        {
            "tstdin": "",
            "command": "stat",
            "description": "时间戳秒数格式测试",
            "setup_commands": [
                "touch epoch_test_file"
            ],
            "args": ["-c", "%X|%Y|%Z|%W", "epoch_test_file"],
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": "^[0-9]+\\|[0-9]+\\|[0-9]+\\|[0-9]+$",
                    "stderr": ""
                }
            },
            "cleanup_commands": [
                "rm -f epoch_test_file"
            ]
        },
        {
            "tstdin": "",
            "command": "stat",
            "description": "文件属性一致性测试（不包含时间戳和inode）",
            "setup_commands": [
                "touch consistent_test_file"
            ],
            "args": ["-c", "%n|%s|%f|%F|%a|%A|%u|%g|%U|%G|%h|%b|%o", "consistent_test_file"],
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": "consistent_test_file\\|0\\|81a4\\|regular empty file\\|644\\|-rw-r--r--\\|0\\|0\\|.*\\|.*\\|1\\|0\\|4096",
                    "stderr": ""
                }
                },
            "cleanup_commands": [
                "rm -f consistent_test_file"
            ]
        },
        {
            "tstdin": "",
            "command": "stat",
            "description": "设备号格式一致性测试",
            "setup_commands": [
                "touch device_format_test"
            ],
            "args": ["-c", "%Hd,%Ld", "device_format_test"],
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": "^[0-9]+,[0-9]+$",
                    "stderr": ""
                }
            },
            "cleanup_commands": [
                "rm -f device_format_test"
            ]
        },
        {
            "tstdin": "",
            "command": "stat",
            "description": "文件系统状态测试",
            "args": ["-f", "/"],
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": ".*File:.*\"/\".*ID:.*Namelen:.*Type:.*Block size:.*Blocks:.*Total:.*Free:.*Available:.*Files:.*Free nodes:.*",
                    "stderr": ""
                }
            },
            "cleanup_commands": []
        },
        {
            "tstdin": "",
            "command": "stat",
            "description": "符号链接格式测试",
            "setup_commands": [
                "touch target_file",
                "ln -s target_file link_file"
            ],
            "args": ["-c", "%N|%F", "link_file"],
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": "'link_file' -> 'target_file'\\|symbolic link",
                    "stderr": ""
                }
            },
            "cleanup_commands": [
                "rm -f target_file link_file"
            ]
        },
        {
            "tstdin": "",
            "command": "stat",
            "description": "符号链接解引用测试",
            "setup_commands": [
                "touch target_file",
                "ln -s target_file link_file"
            ],
            "args": ["-L", "-c", "%n|%F", "link_file"],
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": "link_file\\|regular empty file",
                    "stderr": ""
                }
            },
            "cleanup_commands": [
                "rm -f target_file link_file"
            ]
        },
        {
            "tstdin": "",
            "command": "stat",
            "description": "简洁格式字段数测试",
            "setup_commands": [],
            "args": ["--terse", "/etc/passwd"],
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": "^\\S+( \\S+){15}$",
                    "stderr": ""
                }
            },
            "cleanup_commands": []
        },
        {
            "tstdin": "",
            "command": "stat",
            "description": "多个文件格式测试",
            "setup_commands": [
                "touch file1 file2"
            ],
            "args": ["-c", "%n:%F", "file1", "file2"],
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": "file1:regular empty file\nfile2:regular empty file\n",
                    "stderr": ""
                }
            },
            "cleanup_commands": [
                "rm -f file1 file2"
            ]
        },
        {
            "tstdin": "",
            "command": "stat",
            "description": "文件不存在测试",
            "args": ["nonexistent_file"],
            "expectation": {
                "execution": {
                    "exit_code": 1,
                    "stdout": "",
                    "stderr": ".*cannot stat.*nonexistent_file.*"
                }
            },
            "cleanup_commands": []
        },
        {
            "tstdin": "",
            "command": "stat",
            "description": "printf格式测试",
            "setup_commands": [
                "touch printf_test"
            ],
            "args": ["--printf", "文件名：%n\n大小：%s字节\n类型：%F\n权限：%A\n", "printf_test"],
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": "文件名：printf_test\n大小：0字节\n类型：regular empty file\n权限：-rw-r--r--\n",
                    "stderr": ""
                }
            },
            "cleanup_commands": [
                "rm -f printf_test"
            ]
        },
        {
            "tstdin": "",
            "command": "stat",
            "description": "使用 -c 短选项的格式测试",
            "setup_commands": [
                "touch format_test"
            ],
            "args": ["-c", "%A %U:%G", "format_test"],
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": "-rw-r--r-- root:root\n",
                    "stderr": ""
                }
            },
            "cleanup_commands": [
                "rm -f format_test"
            ]
        },
        {
            "tstdin": "",
            "command": "stat",
            "description": "使用 --printf 的转义字符测试",
            "setup_commands": [
                "touch printf_test"
            ],
            "args": ["--printf", "文件名：%n\\n大小：%s字节\\n类型：%F\\n权限：%A\\n", "printf_test"],
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": "文件名：printf_test\n大小：0字节\n类型：regular empty file\n权限：-rw-r--r--\n",
                    "stderr": ""
                }
            },
            "cleanup_commands": [
                "rm -f printf_test"
            ]
        },
        {
            "tstdin": "",
            "command": "stat",
            "description": "使用 --printf 不自动添加换行符的测试",
            "setup_commands": [
                "touch printf_test"
            ],
            "args": ["--printf", "文件名：%n 大小：%s字节", "printf_test"],
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": "文件名：printf_test 大小：0字节",
                    "stderr": ""
                }
            },
            "cleanup_commands": [
                "rm -f printf_test"
            ]
        },
        {
            "tstdin": "",
            "command": "stat",
            "description": "--cached=always 选项功能测试",
            "setup_commands": [
                "touch cached_test_file"
            ],
            "args": ["--cached=always", "-c", "%n|%F|%s", "cached_test_file"],
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": "cached_test_file\\|regular empty file\\|0",
                    "stderr": ""
                }
            },
            "cleanup_commands": [
                "rm -f cached_test_file"
            ]
        },
        {
            "tstdin": "",
            "command": "stat",
            "description": "--cached=never 选项功能测试",
            "setup_commands": [
                "touch cached_test_file"
            ],
            "args": ["--cached=never", "-c", "%n|%F|%s", "cached_test_file"],
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": "cached_test_file\\|regular empty file\\|0",
                    "stderr": ""
                }
            },
            "cleanup_commands": [
                "rm -f cached_test_file"
            ]
        },
        {
            "tstdin": "",
            "command": "stat",
            "description": "--cached=default 选项功能测试",
            "setup_commands": [
                "touch cached_test_file"
            ],
            "args": ["--cached=default", "-c", "%n|%F|%s", "cached_test_file"],
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": "cached_test_file\\|regular empty file\\|0",
                    "stderr": ""
                }
            },
            "cleanup_commands": [
                "rm -f cached_test_file"
            ]
        },
        {
            "tstdin": "",
            "command": "stat",
            "description": "--cached 选项与文件系统状态结合测试",
            "args": ["--cached=always", "-f", "/"],
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": ".*File:.*\"/\".*ID:.*Namelen:.*Type:.*Block size:.*Blocks:.*Total:.*Free:.*Available:.*Files:.*Free nodes:.*",
                    "stderr": ""
                }
            },
            "cleanup_commands": []
        },
        {
            "tstdin": "",
            "command": "stat",
            "description": "--cached 选项无效值测试",
            "args": ["--cached=invalid", "test_file"],
            "setup_commands": [
                "touch test_file"
            ],
            "expectation": {
                "execution": {
                    "exit_code": 1,
                    "stdout": "",
                    "stderr": ".*invalid.*"
                }
            },
            "cleanup_commands": [
                "rm -f test_file"
            ]
        }
    ]
} 
