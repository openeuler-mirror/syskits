      "setup_commands": [
        "echo -n '' > empty_file.txt"
      ],
      "args": ["empty_file.txt"],
      "expectation": {
        "execution": {
          "exit_code": 0,
          "stdout": "\n00000     0 empty_file.txt\n\n",
