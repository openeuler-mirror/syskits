            "command": "",
            "expected_exit": 0,
            "expected_stdout": ""
          }
        ]
      },
      "cleanup_commands": [
        "rm -rf empty_file.txt"
      ]
    },
    {
        "tstdin": "",
        "command": "sum",
        "description": "测试system v校验和算法",
