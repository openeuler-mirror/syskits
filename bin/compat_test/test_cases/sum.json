          "echo -n 'test' > test3.txt"
        ],
        "args": ["test.txt","test2.txt","test3.txt"],
        "expectation": {
          "execution": {
            "exit_code": 0,
            "stdout": "\n08403     1 test.txt\n53451     1 test2.txt\n16597     1 test3.txt\n\n",
            "stderr": ""
          },
          "verifications": [
            {
              "command": "",
              "expected_exit": 0,
              "expected_stdout": ""
            }
          ]
        },
        "cleanup_commands": [
          "rm -rf test.txt test2.txt test3.txt"
        ]
    },
    {
        "tstdin": "",
        "command": "sum",
        "description": "测试--sysv参数多个文件",
