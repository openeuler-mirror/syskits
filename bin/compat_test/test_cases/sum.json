          "echo -n 'A' > test.txt"
        ],
        "args": ["--sysv","test.txt"],
        "expectation": {
          "execution": {
            "exit_code": 0,
            "stdout": "\n65 1 test.txt\n\n",
            "stderr": ""
          },
          "verifications": [
            {
              "command": "",
              "expected_exit": 0,
              "expected_stdout": ""
            }
          ]
        },
        "cleanup_commands": [
          "rm -rf test.txt"
        ]
    },
    {
        "tstdin": "",
        "command": "sum",
        "description": "测试多个文件",
