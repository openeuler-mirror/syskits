            "args": ["deps_tsort.txt"],
            "setup_commands": [
                "printf 'A B\nB C\n' > deps_tsort.txt"
            ],
            "expectation": {
                "execution": {
                "exit_code": 0,
                "stdout": "A\nB\nC\n",
                "stderr": ""
                },
                "verifications": [
                ],
                "ignore_fields": {
                "ignore_exit_code": false,
                "ignore_stdout": false,
                "ignore_stderr": false,
                "ignore_function": false
                }
            },
            "cleanup_commands": [
                "rm -f deps_tsort.txt"
            ]
        },
