{
    "tests": [
        {
            "tstdin": "",
            "command": "vdir",
            "description": "vdir: 基本列出当前目录（时间中英文区别）",
            "setup_commands": [
                "mkdir test_vdir_vdir_basic",
                "cd test_vdir_vdir_basic",
                "touch a.txt",
                "touch b.txt",
                "touch c.txt",
                "touch .hidden",
                "mkdir subdir"
            ],
            "args": [],
            "expectation": {
                "execution": {
                "exit_code": 0,
                "stdout": "total 0\n-rw-r--r-- 1 root root  0 Jan 16 10:48 a.txt\n-rw-r--r-- 1 root root  0 Jan 16 10:48 b.txt\n-rw-r--r-- 1 root root  0 Jan 16 10:48 c.txt\ndrwxr-xr-x 2 root root 40 Jan 16 10:48 subdir\n",
                "stderr": ""
                }
            },
            "cleanup_commands": [
                "cd ..",
                "rm -rf test_vdir_vdir_basic"
            ]
        },
        {
            "tstdin": "",
            "command": "vdir",
            "description": "vdir: 指定单个目录（时间中英文区别）",
            "setup_commands": [
                "mkdir test_vdir_vdir_basic",
                "cd test_vdir_vdir_basic",
                "touch a.txt",
                "touch b.txt",
                "touch c.txt",
                "touch .hidden",
                "mkdir subdir",
                "cd .."
            ],
            "args": [
                "test_vdir_vdir_basic"
            ],
            "expectation": {
                "execution": {
                "exit_code": 0,
                "stdout": "a.txt\nb.txt\nc.txt\nsubvdir\n",
                "stderr": ""
                }
            },
            "cleanup_commands": [
                "rm -rf test_vdir_vdir_basic"
            ]
        },
        {
            "tstdin": "",
            "command": "vdir",
            "description": "vdir: 指定多个路径（文件+目录）（时间中英文区别）",
            "setup_commands": [
                "mkdir test_vdir_vdir_basic",
                "cd test_vdir_vdir_basic",
                "touch a.txt",
                "touch b.txt",
                "touch c.txt",
                "touch .hidden",
                "mkdir subdir",
                "cd .."
            ],
            "args": [
                "test_vdir_vdir_basic/a.txt",
                "test_vdir_vdir_basic",
                "test_vdir_vdir_basic/subdir"
            ],
            "expectation": {
                "execution": {
                "exit_code": 0,
                "stdout": "-rw-r--r-- 1 root root   0  1月16日 10:53 test_vdir_vdir_basic/a.txt\n\ntest_vdir_vdir_basic:\n总计 0\n-rw-r--r-- 1 root root  0  1月16日 10:53 a.txt\n-rw-r--r-- 1 root root  0  1月16日 10:53 b.txt\n-rw-r--r-- 1 root root  0  1月16日 10:53 c.txt\ndrwxr-xr-x 2 root root 40  1月16日 10:53 subdir\n\ntest_vdir_vdir_basic/subdir:\n总计 0\n",
                "stderr": ""
                }
            },
            "cleanup_commands": [
                "rm -rf test_vdir_vdir_basic"
            ]
        },
        {
            "tstdin": "",
            "command": "vdir",
            "description": "vdir: 错误路径处理",
            "setup_commands": [
                "mkdir test_vdir_vdir_basic",
                "cd test_vdir_vdir_basic",
                "touch a.txt",
                "touch b.txt",
                "touch c.txt",
                "touch .hidden",
                "mkdir subdir",
                "cd .."
            ],
            "args": [
                "test_vdir_vdir_basic/a.txt",
                "not_exist_file",
                "test_vdir_vdir_basic/subdir"
            ],
            "expectation": {
                "execution": {
                "exit_code": 2,
                "stdout": "-rw-r--r-- 1 root root 0 Jan 16 11:00 test_vdir_vdir_basic/a.txt\n\ntest_vdir_vdir_basic/subdir:\ntotal 0\n",
                "stderr": ""
                }
            },
            "cleanup_commands": [
                "rm -rf test_vdir_vdir_basic"
            ]
        },
        {
            "tstdin": "",
            "command": "vdir",
            "description": "vdir: 使用-a显示所有的文件（时间中英文区别）",
