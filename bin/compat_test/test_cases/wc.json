{
    "tests": [
        {
            "tstdin": "",
            "command": "wc",
            "description": "wc: 基本统计文件行数、字数和字符数",
            "setup_commands": [
                "echo 'line1: hello, world!\nline2: this is a test.\nline3: wc command test.' > test_wc.txt"
            ],
            "args": [
                "test_wc.txt"
            ],
            "expectation": {
                "execution": {
                "exit_code": 0,
                "stdout": " 3 12 68 test_wc.txt\n",
                "stderr": ""
                }
            },
            "cleanup_commands": [
                "rm -f test_wc.txt"
            ]
        },
        {
            "tstdin": "",
            "command": "wc",
            "description": "wc: 多文件输入（仅有中英文差异）",
            "setup_commands": [
                "echo 'line1: hello, world!\nline2: this is a test.\nline3: wc command test.' > test_wc1.txt",
                "echo 'line1: hello, world!\nline2: this are a test.\nline3: hi!\nhey!' > test_wc2.txt"
            ],
            "args": [
                "test_wc1.txt",
                "test_wc2.txt"
            ],
            "expectation": {
                "execution": {
                "exit_code": 0,
                "stdout": " 3  12  68 test_wc1.txt\n  4  11  61 test_wc2.txt\n  7  23 129 total\n",
                "stderr": ""
                }
            },
            "cleanup_commands": [
                "rm -f test_wc1.txt test_wc2.txt"
            ]
        },
        {
            "tstdin": "",
            "command": "wc",
            "description": "wc: 部分文件不存在",
            "setup_commands": [
                "echo 'line1: hello, world!\nline2: this is a test.\nline3: wc command test.' > test_wc1.txt",
                "echo 'line1: hello, world!\nline2: this are a test.\nline3: hi!\nhey!' > test_wc2.txt"
            ],
            "args": [
                "test_wc1.txt",
                "missing.txt",
                "test_wc2.txt"
            ],
            "expectation": {
                "execution": {
                "exit_code": 1,
                "stdout": "  3  12  68 test_wc1.txt\n  4  11  61 test_wc2.txt\n  7  23 129 total\n",
                "stderr": ""
                }
            },
            "cleanup_commands": [
                "rm -f test_wc1.txt test_wc2.txt"
            ]
        },
