          },
          "verifications": [
            {
              "command": "",
              "expected_exit": 0,
              "expected_stdout": ""
            }

          ]
        },
        "cleanup_commands": [
          "rm -rf test1.txt"
        ]
      },
      {
        "tstdin": "",
        "command": "cut",
        "description": "测试cut处理制表符功能",
        "setup_commands": [
