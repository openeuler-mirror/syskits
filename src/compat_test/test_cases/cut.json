{
    "tests": [
      {
        "tstdin": "",
        "command": "cut",
        "description": "测试cut指定字段和分隔符功能",
        "setup_commands": [
          "echo -e 'Alice:25:Engineer\nBob:30:Designer\nCharlie::Manager' > test1.txt"
        ],
        "args": ["-d", ":", "-f", "2", "test1.txt"],
        "expectation": {
          "execution": {
            "exit_code": 0,
            "stdout": "\n25\n30\n\n\n",
            "stderr": ""
          },
          "verifications": [
            {
              "command": "",
              "expected_exit": 0,
              "expected_stdout": ""
            }

          ]
        },
        "cleanup_commands": [
          "rm -rf test1.txt"
        ]
      },

      {
        "tstdin": "",
        "command": "cut",
        "description": "测试cut补全功能",
        "setup_commands": [
          "echo -e 'Alice:25:Engineer\nBob:30:Designer\nCharlie::Manager' > test1.txt"
        ],
        "args": ["-d", ":", "-f", "1", "--complement", "test1.txt"],
        "expectation": {
          "execution": {
            "exit_code": 0,
            "stdout": "\n25:Engineer\n30:Designer\n:Manager\n\n",
            "stderr": ""
          },
          "verifications": [
            {
              "command": "",
              "expected_exit": 0,
              "expected_stdout": ""
            }

          ]
        },
        "cleanup_commands": [
          "rm -rf test1.txt"
        ]
      },

      {
        "tstdin": "",
        "command": "cut",
        "description": "测试cut不打印没有包含分界符的行功能",
        "setup_commands": [
          "echo -e 'Alice:25:Engineer\nBob:30:Designer\nCharlie::Manager' > test1.txt"
        ],
        "args": ["-d", ":", "-s", "-f", "1", "test1.txt"],
        "expectation": {
          "execution": {
            "exit_code": 0,
            "stdout": "\nAlice\nBob\nCharlie\n\n",
            "stderr": ""
          },
          "verifications": [
            {
              "command": "",
              "expected_exit": 0,
              "expected_stdout": ""
            }

          ]
        },
        "cleanup_commands": [
          "rm -rf test1.txt"
        ]
      },

      {
        "tstdin": "",
        "command": "cut",
        "description": "测试cut选中指定字节功能",
        "setup_commands": [
          "echo -e '中文测试\n🍎🍌🍒\nHello\tWorld' > test3.txt"
        ],
        "args": ["-b", "1-3", "test3.txt"],
        "expectation": {
          "execution": {
            "exit_code": 0,
            "stdout": "\n中\n🍎\nHel\n\n",
            "stderr": ""
          },
          "verifications": [
            {
              "command": "",
              "expected_exit": 0,
              "expected_stdout": ""
            }

          ]
        },
        "cleanup_commands": [
          "rm -rf test3.txt"
        ]
      },

      {
        "tstdin": "",
        "command": "cut",
        "description": "测试cut选中指定字符功能",
        "setup_commands": [
          "echo -e '中文测试\n🍎🍌🍒\nHello\tWorld' > test3.txt",
          "cut -c 1-3 test3.txt"
        ],
        "args": ["-c", "1-3", "test3.txt"],
        "expectation": {
          "execution": {
            "exit_code": 0,
            "stdout": "\n中文测\n🍎🍌🍒\nHel\n\n",
            "stderr": ""
          },
          "verifications": [
            {
              "command": "",
              "expected_exit": 0,
              "expected_stdout": ""
            }

          ]
        },
        "cleanup_commands": [
          "rm -rf test3.txt"
        ]
      },

      {
        "tstdin": "",
        "command": "cut",
        "description": "测试cut使用指定的字符串作为输出分界符",
        "setup_commands": [
          "echo -e 'A,B,C,D\n1,,3,4\nX,Y,Z,' > test2.txt"
        ],
        "args": ["-d", ",", "-f", "1,3", "--output-delimiter", "|", "test2.txt"],
        "expectation": {
          "execution": {
            "exit_code": 0,
            "stdout": "\nA|C\n1|3\nX|Z\n\n",
            "stderr": ""
          },
          "verifications": [
            {
              "command": "",
              "expected_exit": 0,
              "expected_stdout": ""
            }

          ]
        },
        "cleanup_commands": [
          "rm -rf test2.txt"
        ]
      },

      {
        "tstdin": "",
        "command": "cut",
        "description": "测试cut混合字段和范围（-f 列表）",
        "setup_commands": [
          "echo -e 'A,B,C,D\n1,,3,4\nX,Y,Z,' > test2.txt"
        ],
        "args": ["-d", ",", "-f", "1,3-4", "test2.txt"],
        "expectation": {
          "execution": {
            "exit_code": 0,
            "stdout": "\nA,C,D\n1,3,4\nX,Z,\n\n",
            "stderr": ""
          },
          "verifications": [
            {
              "command": "",
              "expected_exit": 0,
              "expected_stdout": ""
            }

          ]
        },
        "cleanup_commands": [
          "rm -rf test2.txt"
        ]
      },

      {
        "tstdin": "",
        "command": "cut",
        "description": "测试cut提取超出字段范围的列",
        "setup_commands": [
          "echo -e 'A,B,C,D\n1,,3,4\nX,Y,Z,' > test2.txt"
        ],
        "args": ["-d", ",", "-f", "5", "test2.txt"],
        "expectation": {
          "execution": {
            "exit_code": 0,
            "stdout": "\n\n\n\n\n",
            "stderr": ""
          },
          "verifications": [
            {
              "command": "",
              "expected_exit": 0,
              "expected_stdout": ""
            }

          ]
        },
        "cleanup_commands": [
          "rm -rf test2.txt"
        ]
      },
      {
        "tstdin": "Hello:World",
