{
    "tests": [
        {
            "tstdin": "",
            "command": "paste",
            "description": "基本功能测试 - 合并两个文件",
            "setup_commands": [
                "echo -e 'a\\nb\\nc' > file1",
                "echo -e '1\\n2\\n3' > file2"
            ],
            "args": ["file1", "file2"],
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": "a\t1\nb\t2\nc\t3\n",
                    "stderr": ""
                }
            },
            "cleanup_commands": [
                "rm -f file1 file2"
            ]
        },
        {
            "tstdin": "",
            "command": "paste",
            "description": "使用自定义分隔符",
            "setup_commands": [
                "echo -e 'a\\nb\\nc' > file1",
                "echo -e '1\\n2\\n3' > file2"
            ],
            "args": ["-d", ",", "file1", "file2"],
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": "a,1\nb,2\nc,3\n",
                    "stderr": ""
                }
            },
            "cleanup_commands": [
                "rm -f file1 file2"
            ]
        },
        {
            "tstdin": "",
            "command": "paste",
            "description": "串行模式测试",
            "setup_commands": [
                "echo -e 'a\\nb\\nc' > file1",
                "echo -e '1\\n2\\n3' > file2"
            ],
            "args": ["-s", "file1", "file2"],
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": "a\tb\tc\n1\t2\t3\n",
                    "stderr": ""
                }
            },
            "cleanup_commands": [
                "rm -f file1 file2"
            ]
        },
        {
            "tstdin": "",
            "command": "paste",
            "description": "文件不存在测试",
            "args": ["nonexistent_file"],
            "expectation": {
                "execution": {
                    "exit_code": 1,
                    "stdout": "",
                    "stderr": "paste: nonexistent_file: No such file or directory\n"
                }
            },
            "cleanup_commands": []
        },
        {
            "tstdin": "",
            "command": "paste",
            "description": "使用 NUL 字符作为行尾分隔符",
            "setup_commands": [
                "printf 'a\\0b\\0c\\0' > file1_null",
                "printf '1\\02\\03\\0' > file2_null"
            ],
            "args": ["-z", "file1_null", "file2_null"],
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": "",
                    "stderr": ""
                }
            },
            "cleanup_commands": [
                "rm -f file1_null file2_null"
            ]
        },
        {
            "tstdin": "",
            "command": "paste",
            "description": "使用 --zero-terminated 长选项",
            "setup_commands": [
                "printf 'a\\0b\\0c\\0' > file1_null",
                "printf '1\\02\\03\\0' > file2_null"
            ],
            "args": ["--zero-terminated", "file1_null", "file2_null"],
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": "",
                    "stderr": ""
                }
            },
            "cleanup_commands": [
                "rm -f file1_null file2_null"
            ]
        },
        {
            "tstdin": "",
            "command": "paste",
            "description": "零终止符与自定义分隔符结合",
            "setup_commands": [
                "printf 'a\\0b\\0c\\0' > file1_null",
                "printf '1\\02\\03\\0' > file2_null"
            ],
            "args": ["-z", "-d", ",", "file1_null", "file2_null"],
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": "",
                    "stderr": ""
                }
            },
            "cleanup_commands": [
                "rm -f file1_null file2_null"
            ]
        },
        {
            "tstdin": "",
            "command": "paste",
            "description": "零终止符与串行模式结合",
            "setup_commands": [
                "printf 'a\\0b\\0c\\0' > file1_null",
                "printf '1\\02\\03\\0' > file2_null"
            ],
            "args": ["-z", "-s", "file1_null", "file2_null"],
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": "",
                    "stderr": ""
                }
            },
            "cleanup_commands": [
                "rm -f file1_null file2_null"
            ]
        }
        
    ]
} 