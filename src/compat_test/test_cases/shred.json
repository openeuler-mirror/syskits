{
    "tests": [
        {
            "tstdin": "",
            "command": "shred",
            "description": "基本功能测试",
            "setup_commands": [
                "echo 'test' > test_file"
            ],
            "args": ["test_file"],
            "expectation": {
                "execution": {
                    "exit_code": 0,
                    "stdout": "",
                    "stderr": ""
                }
            },
            "verifications": [
                {
                    "command": "cat test_file | grep test",
                    "expected_exit": 0,
                    "expected_stdout": ""
                }
            ],
            "cleanup_commands": [
                "rm -f test_file"
            ]
        },
        {
            "tstdin": "",
            "command": "shred",
            "description": "测试-v参数",
